#!/bin/bash
# bin/rite-health-report — Sharkrite Operational Health Report
#
# Two-stage pipeline:
#   1. Bash collects raw data from logs, rtk stats, git history, previous reports
#   2. Claude analyzes the data and generates an actionable markdown report
#
# Writes report to .rite/reports/rite-health-YYYYMMDD.md
#
# Usage:
#   rite-health-report              # Generate new report
#   rite-health-report --latest     # Display most recent report without regenerating
#   rite-health-report --display    # Generate and display (used by rite --rtk-report)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="${RITE_PROJECT_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"
DATA_DIR="${RITE_DATA_DIR:-.rite}"
LOGS_DIR="$PROJECT_ROOT/$DATA_DIR/logs"
REPORTS_DIR="$PROJECT_ROOT/$DATA_DIR/reports"
DISPLAY_MODE=false
MIN_WORKFLOWS=3

# Parse args
case "${1:-}" in
  --latest)
    latest=$(find "$REPORTS_DIR" -name "rite-health-*.md" 2>/dev/null | sort | tail -1 || true)
    if [ -n "$latest" ]; then
      cat "$latest"
    else
      echo "No health reports found in $REPORTS_DIR"
    fi
    exit 0
    ;;
  --display)
    DISPLAY_MODE=true
    ;;
esac

# Pre-checks
if ! command -v claude &>/dev/null; then
  echo "Error: claude CLI not found. Required for report analysis."
  exit 1
fi

if ! command -v jq &>/dev/null; then
  echo "Error: jq not found. Required for data parsing."
  exit 1
fi

mkdir -p "$REPORTS_DIR"

TODAY=$(date +%Y-%m-%d)
TODAY_COMPACT=$(date +%Y%m%d)
REPORT_FILE="$REPORTS_DIR/rite-health-${TODAY_COMPACT}.md"

# =============================================================================
# Date helpers (BSD/GNU compatible)
# =============================================================================

epoch_days_ago() {
  local days="$1"
  if date -v-${days}d +%s &>/dev/null 2>&1; then
    date -v-${days}d +%s
  else
    date -d "${days} days ago" +%s
  fi
}

date_from_compact() {
  local compact="$1"
  if date -j -f "%Y%m%d" "$compact" +%s 2>/dev/null; then
    return 0
  else
    date -d "$compact" +%s 2>/dev/null || echo "0"
  fi
}

WEEK_AGO_EPOCH=$(epoch_days_ago 7)

# =============================================================================
# Stage 1: Collect raw data
# =============================================================================

# --- Recent log files (past 7 days) ---
RECENT_LOGS=()
if [ -d "$LOGS_DIR" ]; then
  while IFS= read -r logfile; do
    _log_date=$(echo "$logfile" | grep -oE '[0-9]{8}-[0-9]{6}' | tail -1 | cut -d- -f1 || true)
    if [ -n "$_log_date" ]; then
      _log_epoch=$(date_from_compact "$_log_date")
      if [ "${_log_epoch:-0}" -ge "$WEEK_AGO_EPOCH" ] 2>/dev/null; then
        RECENT_LOGS+=("$logfile")
      fi
    fi
  done < <(find "$LOGS_DIR" -name "rite-*.log" -type f 2>/dev/null | sort)
fi

# --- Extract diagnostic lines from recent logs ---
DIAG_LINES=""
TIMING_LINES=""
for logfile in "${RECENT_LOGS[@]+"${RECENT_LOGS[@]}"}"; do
  DIAG_LINES+=$(grep '\[diag\]' "$logfile" 2>/dev/null || true)
  DIAG_LINES+=$'\n'
  TIMING_LINES+=$(grep '\[timing\].*END' "$logfile" 2>/dev/null || true)
  TIMING_LINES+=$'\n'
done

# Clean up blank lines
DIAG_LINES=$(echo "$DIAG_LINES" | sed '/^$/d' || true)
TIMING_LINES=$(echo "$TIMING_LINES" | sed '/^$/d' || true)

# --- Pre-parse conflict resolver stats for health checks ---
# Extract CONFLICT_RESOLVER exit-event lines (not START lines; those are entry events)
CR_LINES=$(echo "$DIAG_LINES" | grep 'CONFLICT_RESOLVER ' || true)
CR_TOTAL=$(echo "$CR_LINES" | grep -c 'CONFLICT_RESOLVER ' || true)
CR_RESOLVED=$(echo "$CR_LINES" | grep -c 'outcome=resolved' || true)
CR_FAILED=$(echo "$CR_LINES" | grep -c 'outcome=failed' || true)
CR_CAP_HIT=$(echo "$CR_LINES" | grep -c 'outcome=cap_hit' || true)
CR_SKIPPED=$(echo "$CR_LINES" | grep -c 'outcome=skipped_no_resolver' || true)

# --- Pre-parse test gate stats for health checks ---
# TEST_GATE diag format: "TEST_GATE outcome=passed|failed|skipped lint_count=N test_count=N duration_s=N pr=N"
TG_LINES=$(echo "$DIAG_LINES" | grep 'TEST_GATE ' || true)
TG_TOTAL=$(echo "$TG_LINES" | grep -c 'TEST_GATE ' || true)
TG_PASSED=$(echo "$TG_LINES" | grep -c 'outcome=passed' || true)
TG_FAILED=$(echo "$TG_LINES" | grep -c 'outcome=failed' || true)
TG_SKIPPED=$(echo "$TG_LINES" | grep -c 'outcome=skipped' || true)
# Sum lint and test failure counts across all gate runs
TG_LINT_TOTAL=$(echo "$TG_LINES" | grep -oE 'lint_count=[0-9]+' | grep -oE '[0-9]+' | awk '{sum += $1} END {print sum+0}' || echo "0")
TG_TEST_TOTAL=$(echo "$TG_LINES" | grep -oE 'test_count=[0-9]+' | grep -oE '[0-9]+' | awk '{sum += $1} END {print sum+0}' || echo "0")

# --- Pre-parse test-gate selection stats for health checks ---
# TEST_GATE_SELECTION diag format: "TEST_GATE_SELECTION mode=targeted|full selected=N total=N issue=N"
TGS_LINES=$(echo "$DIAG_LINES" | grep 'TEST_GATE_SELECTION ' || true)
TGS_TOTAL=$(echo "$TGS_LINES" | grep -c 'TEST_GATE_SELECTION ' || true)
TGS_TARGETED=$(echo "$TGS_LINES" | grep -c 'mode=targeted' || true)
TGS_FULL=$(echo "$TGS_LINES" | grep -c 'mode=full' || true)
# Compute average selection ratio: sum(selected/total) across targeted runs
# Use awk to safely handle division-by-zero when total=0
TGS_AVG_RATIO=$(echo "$TGS_LINES" | grep 'mode=targeted' | \
  awk '{
    sel=0; tot=0
    for (i=1;i<=NF;i++) {
      if ($i ~ /^selected=/) { sub(/selected=/, "", $i); sel=$i }
      if ($i ~ /^total=/)    { sub(/total=/,    "", $i); tot=$i }
    }
    if (tot > 0) { sum += sel/tot; count++ }
  } END { if (count > 0) printf "%.0f", (sum/count)*100; else print "N/A" }' || echo "N/A")

# --- Count workflow completions (minimum data gate) ---
WORKFLOW_COUNT=$(echo "$DIAG_LINES" | grep -c 'WORKFLOW_COMPLETE' || true)

if [ "$WORKFLOW_COUNT" -lt "$MIN_WORKFLOWS" ]; then
  {
    echo "# Sharkrite Health Report — $TODAY"
    echo ""
    echo "Insufficient data: $WORKFLOW_COUNT workflow completions in the past 7 days (need $MIN_WORKFLOWS+)."
    echo ""
    echo "This report will generate automatically once enough workflows have run with diagnostic logging enabled."
  } > "$REPORT_FILE"
  echo "Insufficient data ($WORKFLOW_COUNT workflows, need $MIN_WORKFLOWS+). Report skipped."
  if [ "$DISPLAY_MODE" = "true" ]; then
    cat "$REPORT_FILE"
  fi
  exit 0
fi

# --- rtk stats (if installed) ---
RTK_STATS=""
if command -v rtk &>/dev/null; then
  RTK_STATS=$(rtk gain --format json 2>/dev/null || echo "rtk gain failed")
fi

# --- Recent sharkrite changes (git log on the tool itself) ---
SHARKRITE_CHANGES=""
if [ -d "$PROJECT_ROOT/.git" ]; then
  SHARKRITE_CHANGES=$(cd "$PROJECT_ROOT" && git log --oneline --since="7 days ago" --stat 2>/dev/null || echo "No recent commits")
fi

# --- Previous reports (last 2 for trend context) ---
PREV_REPORTS=""
prev_files=$(find "$REPORTS_DIR" -name "rite-health-*.md" ! -name "rite-health-${TODAY_COMPACT}.md" 2>/dev/null | sort | tail -2 || true)
for prev_file in $prev_files; do
  PREV_REPORTS+="--- $(basename "$prev_file") ---"$'\n'
  PREV_REPORTS+=$(cat "$prev_file" 2>/dev/null || true)
  PREV_REPORTS+=$'\n\n'
done

# =============================================================================
# Stage 2: Build prompt and invoke Claude
# =============================================================================

PROMPT_FILE=$(mktemp)
trap 'rm -f "$PROMPT_FILE"' EXIT

cat > "$PROMPT_FILE" << 'SYSTEM_PROMPT'
You are an operational analyst for Sharkrite, an AI-powered GitHub workflow automation CLI. You are generating a weekly health report based on diagnostic log data.

## Your Task

Analyze the provided data and produce a concise markdown health report. Be direct and actionable. No fluff.

## Report Sections

1. **Summary** — 2-3 sentence overview of the week
2. **Metrics** — Issues processed, token savings (if rtk active), fix loop iterations, phase durations
3. **Health Checks** — Flag anything concerning using these absolute thresholds:
   - Fix iterations avg > 2.0 → WARNING
   - Any phase failing > 30% of the time → WARNING
   - Phase 1 (dev) duration avg > 20 min → WATCH
   - rtk savings < 30% avg → WATCH (possible over-compression)
   - Any issue hitting max fix iterations (3) → flag that specific issue
   - Review finding 0 issues consistently → WATCH (review prompt may be too lenient)
   - CRITICAL findings appearing → flag
4. **Test Gate** — Summarize post-commit verification gate stats using the pre-parsed stats provided:
   - Show: Total gate runs, outcome breakdown (passed/failed/skipped), lint failures total, bats test failures total
   - Show: Test selection stats — targeted runs vs full-suite runs, avg selection ratio
   - Thresholds:
     - gate failure rate > 30% → **WARNING**: "Fix sessions introducing regressions frequently"
     - `skipped` > 0 → **WATCH**: "Gate skipped (bats/make missing on some runners)"
     - TG_LINT_TOTAL > 0 → flag which fix iterations introduced lint violations
     - TGS_AVG_RATIO < 50% (on targeted runs) → **WARNING**: "Test coverage header adoption lagging — targeted selection not saving much work; backfill sharkrite-test-covers: headers in high-traffic bats files"
     - TGS_FULL / TGS_TOTAL > 30% → note: "Many full-suite runs (infra files changed frequently)"
   - If TG_TOTAL is 0, say "No post-commit gate runs recorded this week (feature new or gate not yet active)."
   - If TGS_TOTAL is 0, say "No test-selection diag recorded — test-gate selection feature may not yet be active."
5. **Conflict Resolver** — Summarize conflict resolution attempts using the pre-parsed stats provided:
   - Show: Total invocations, outcome breakdown (resolved/failed/cap_hit/skipped_no_resolver), most affected issues (top 5), median resolution duration if duration_s values are present
   - Thresholds:
     - `skipped_no_resolver` > 0 → **WARNING**: "Resolver not wired — conflict-resolver.sh may be missing"
     - failure rate > 30% → **WATCH**: "Resolver failing frequently"
   - If CR_TOTAL is 0, say "No conflict resolution attempts this week."
6. **Sharkrite Changes** — If tool code changed this week, note which subsystems were modified. Correlate with any metric shifts (e.g., "assess-and-resolve.sh modified 3 days ago; Phase 3 metrics show no degradation — change appears safe"). If no changes, say "No tool changes this week."
7. **Insights** — Patterns, correlations, or observations from the data. Cross-reference with previous reports if provided. Are previously flagged issues improving?
8. **Action Items** — Specific, actionable recommendations. Examples:
   - "Consider adding `gh pr diff` to rtk exclude list — Phase 3 fix iterations up"
   - "Phase 1 duration trending down — rtk compression appears effective"
   - "Review severity skewing toward LOW — tighten review prompt for more meaningful findings"
   If everything looks healthy, say "No action needed — continue monitoring."

## Data Format

- `[diag]` lines are structured: `WORKFLOW_COMPLETE`, `ASSESSMENT`, `REVIEW`, `PHASE_FAILED`, `SESSION`, `CONFLICT_RESOLVER`, `TEST_GATE`, `TEST_GATE_SELECTION`
- `[timing]` lines show phase durations: `END phase_name (Xm Xs)`
- rtk stats are JSON from `rtk gain --format json`
- Git log shows recent tool changes with file stats
- Previous reports provide trend context
- Pre-parsed conflict resolver stats: CR_TOTAL, CR_RESOLVED, CR_FAILED, CR_CAP_HIT, CR_SKIPPED (counts)
- Pre-parsed test gate stats: TG_TOTAL, TG_PASSED, TG_FAILED, TG_SKIPPED, TG_LINT_TOTAL, TG_TEST_TOTAL (counts)
- Pre-parsed test gate selection stats: TGS_TOTAL, TGS_TARGETED, TGS_FULL, TGS_AVG_RATIO (avg % of suite selected on targeted runs)

## Constraints

- Output ONLY the markdown report. No preamble, no explanation of your process.
- Keep it scannable — use bullet points, not paragraphs.
- Be specific when flagging issues (mention issue numbers, phase names, exact metrics).
- If data is sparse for a section, say so briefly and move on.
SYSTEM_PROMPT

cat >> "$PROMPT_FILE" << DATABLOCK

---

## Diagnostic Log Lines (past 7 days)

$DIAG_LINES

## Phase Timing Lines (past 7 days)

$TIMING_LINES

## Test Gate Stats (pre-parsed, past 7 days)

- TG_TOTAL (total gate runs): $TG_TOTAL
- TG_PASSED: $TG_PASSED
- TG_FAILED: $TG_FAILED
- TG_SKIPPED (missing runner): $TG_SKIPPED
- TG_LINT_TOTAL (total lint failures across all failed runs): $TG_LINT_TOTAL
- TG_TEST_TOTAL (total bats test failures across all failed runs): $TG_TEST_TOTAL

## Test Gate Selection Stats (pre-parsed, past 7 days)

- TGS_TOTAL (total TEST_GATE_SELECTION diag lines): $TGS_TOTAL
- TGS_TARGETED (mode=targeted runs — partial bats subset): $TGS_TARGETED
- TGS_FULL (mode=full runs — full suite, trigger files changed): $TGS_FULL
- TGS_AVG_RATIO (avg selected/total ratio on targeted runs, as %): $TGS_AVG_RATIO%
  - WARNING fires at < 50% (indicates sharkrite-test-covers: header adoption is lagging)

Raw TEST_GATE diag lines for per-run details:
$TG_LINES

Raw TEST_GATE_SELECTION diag lines for per-run details:
$TGS_LINES

## Conflict Resolver Stats (pre-parsed, past 7 days)

- CR_TOTAL (total invocations): $CR_TOTAL
- CR_RESOLVED: $CR_RESOLVED
- CR_FAILED: $CR_FAILED
- CR_CAP_HIT: $CR_CAP_HIT
- CR_SKIPPED (skipped_no_resolver — canary): $CR_SKIPPED

Raw CONFLICT_RESOLVER diag lines for issue/duration details:
$CR_LINES

## rtk Token Stats (cumulative)

$RTK_STATS

## Recent Sharkrite Tool Changes (past 7 days)

$SHARKRITE_CHANGES

## Previous Reports

$PREV_REPORTS

---

Generate the Sharkrite weekly health report for $TODAY.
DATABLOCK

# --- Invoke provider ---
echo "Generating health report..."

# Source provider abstraction
RITE_LIB_DIR="${RITE_LIB_DIR:-$SCRIPT_DIR/../lib}"
source "$RITE_LIB_DIR/providers/provider-interface.sh"
load_provider "${RITE_UTILITY_PROVIDER:-claude}"
provider_detect_cli || exit 1

REPORT_OUTPUT=$(provider_run_prompt "$(cat "$PROMPT_FILE")" "" true 2>/dev/null) || {
  echo "Error: Provider analysis failed (exit code $?)"
  exit 1
}

if [ -z "$REPORT_OUTPUT" ]; then
  echo "Error: Claude returned empty output"
  exit 1
fi

# Write report
echo "$REPORT_OUTPUT" > "$REPORT_FILE"
echo "" >> "$REPORT_FILE"
echo "---" >> "$REPORT_FILE"
echo "*Generated by rite-health-report on $(date '+%Y-%m-%d %H:%M:%S')*" >> "$REPORT_FILE"

echo "Report written to: $REPORT_FILE"

if [ "$DISPLAY_MODE" = "true" ]; then
  echo ""
  cat "$REPORT_FILE"
fi

# --- Auto-prune reports older than 90 days ---
PRUNE_EPOCH=$(epoch_days_ago 90)
find "$REPORTS_DIR" -name "rite-health-*.md" -type f 2>/dev/null | while read -r old_report; do
  _old_date=$(echo "$old_report" | grep -oE '[0-9]{8}' | tail -1 || true)
  if [ -n "$_old_date" ]; then
    _old_epoch=$(date_from_compact "$_old_date")
    if [ "${_old_epoch:-999999999999}" -lt "$PRUNE_EPOCH" ] 2>/dev/null; then
      rm -f "$old_report"
    fi
  fi
done
