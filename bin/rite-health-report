#!/bin/bash
# bin/rite-health-report ŌĆö Sharkrite Operational Health Report
#
# Two-stage pipeline:
#   1. Bash collects raw data from logs, rtk stats, git history, previous reports
#   2. Claude analyzes the data and generates an actionable markdown report
#
# Writes report to .rite/reports/rite-health-YYYYMMDD.md
#
# Usage:
#   rite-health-report              # Generate new report
#   rite-health-report --latest     # Display most recent report without regenerating
#   rite-health-report --display    # Generate and display (used by rite --rtk-report)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="${RITE_PROJECT_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"

# Source markers.sh so the report prompt can reference marker constants
# (e.g., ${RITE_MARKER_TEST_COVERS}) without embedding literal sharkrite-* strings
# that would trip the RAW_MARKER_LITERAL lint rule.
# shellcheck source=../lib/utils/markers.sh
[ -f "$SCRIPT_DIR/../lib/utils/markers.sh" ] && source "$SCRIPT_DIR/../lib/utils/markers.sh"
DATA_DIR="${RITE_DATA_DIR:-.rite}"
LOGS_DIR="$PROJECT_ROOT/$DATA_DIR/logs"
REPORTS_DIR="$PROJECT_ROOT/$DATA_DIR/reports"
DISPLAY_MODE=false
# Minimum workflow completions in the window before a full report is generated.
# Override for high- or low-volume projects via RITE_HEALTH_MIN_WORKFLOWS.
MIN_WORKFLOWS="${RITE_HEALTH_MIN_WORKFLOWS:-3}"

# Model for the health-report synthesis ŌĆö DECOUPLED from RITE_REVIEW_MODEL.
# The report is not code review: most of it is templating pre-computed stats
# and applying fixed thresholds, with a thin interpretive tail (Trends, Insights,
# Analyst's read). That is sonnet's sweet spot, not opus's ŌĆö and defaulting here
# stops the report from silently riding the (expensive) code-review model.
# Override to claude-opus-4-8 if a quality check shows the synthesis needs
# deeper reasoning. Mirrors the RITE_DOC_ASSESSMENT_MODEL decoupling
# (see CLAUDE.md ŌåÆ "Model Selection Per Task").
RITE_HEALTH_MODEL="${RITE_HEALTH_MODEL:-claude-sonnet-4-6}"

# Parse args
case "${1:-}" in
  --latest)
    latest=$(find "$REPORTS_DIR" -name "rite-health-*.md" 2>/dev/null | sort | tail -1 || true)
    if [ -n "$latest" ]; then
      cat "$latest"
    else
      echo "No health reports found in $REPORTS_DIR"
    fi
    exit 0
    ;;
  --display)
    DISPLAY_MODE=true
    ;;
esac

# Pre-checks
if ! command -v claude &>/dev/null; then
  echo "Error: claude CLI not found. Required for report analysis."
  exit 1
fi

if ! command -v jq &>/dev/null; then
  echo "Error: jq not found. Required for data parsing."
  exit 1
fi

mkdir -p "$REPORTS_DIR"

TODAY=$(date +%Y-%m-%d)
TODAY_COMPACT=$(date +%Y%m%d)
REPORT_FILE="$REPORTS_DIR/rite-health-${TODAY_COMPACT}.md"

# =============================================================================
# Date helpers (BSD/GNU compatible)
# =============================================================================

epoch_days_ago() {
  local days="$1"
  if date -v-${days}d +%s &>/dev/null 2>&1; then
    date -v-${days}d +%s
  else
    date -d "${days} days ago" +%s
  fi
}

date_from_compact() {
  local compact="$1"
  if date -j -f "%Y%m%d" "$compact" +%s 2>/dev/null; then
    return 0
  else
    date -d "$compact" +%s 2>/dev/null || echo "0"
  fi
}

WEEK_AGO_EPOCH=$(epoch_days_ago 7)

# =============================================================================
# Stage 1: Collect raw data
# =============================================================================

# --- Recent log files (past 7 days) ---
RECENT_LOGS=()
if [ -d "$LOGS_DIR" ]; then
  while IFS= read -r logfile; do
    _log_date=$(echo "$logfile" | grep -oE '[0-9]{8}-[0-9]{6}' | tail -1 | cut -d- -f1 || true)
    if [ -n "$_log_date" ]; then
      _log_epoch=$(date_from_compact "$_log_date")
      if [ "${_log_epoch:-0}" -ge "$WEEK_AGO_EPOCH" ] 2>/dev/null; then
        RECENT_LOGS+=("$logfile")
      fi
    fi
  done < <(find "$LOGS_DIR" -name "rite-*.log" -type f 2>/dev/null | sort)
fi

# --- Extract diagnostic lines from recent logs ---
DIAG_LINES=""
TIMING_LINES=""
for logfile in "${RECENT_LOGS[@]+"${RECENT_LOGS[@]}"}"; do
  DIAG_LINES+=$(grep '\[diag\]' "$logfile" 2>/dev/null || true)
  DIAG_LINES+=$'\n'
  TIMING_LINES+=$(grep '\[timing\].*END' "$logfile" 2>/dev/null || true)
  TIMING_LINES+=$'\n'
done

# Clean up blank lines
DIAG_LINES=$(echo "$DIAG_LINES" | sed '/^$/d' || true)
TIMING_LINES=$(echo "$TIMING_LINES" | sed '/^$/d' || true)

# --- Pre-parse conflict resolver stats for health checks ---
# Extract CONFLICT_RESOLVER exit-event lines (not START lines; those are entry events)
CR_LINES=$(echo "$DIAG_LINES" | grep 'CONFLICT_RESOLVER ' || true)
CR_TOTAL=$(echo "$CR_LINES" | grep -c 'CONFLICT_RESOLVER ' || true)
CR_RESOLVED=$(echo "$CR_LINES" | grep -c 'outcome=resolved' || true)
CR_FAILED=$(echo "$CR_LINES" | grep -c 'outcome=failed' || true)
CR_CAP_HIT=$(echo "$CR_LINES" | grep -c 'outcome=cap_hit' || true)
CR_SKIPPED=$(echo "$CR_LINES" | grep -c 'outcome=skipped_no_resolver' || true)

# --- Pre-compute top-5 most-affected issues from CR_LINES ---
# Bare-marker guard: require digits after "issue=" to avoid matching placeholder text.
# Counts per issue number, sorts descending, takes top 5, formats as "#N (Kx), ...".
# Uses a portable while-read loop (bash 3.2 compatible ŌĆö no mapfile/declare -A).
CR_TOP5_ISSUES="N/A"
if [ -n "$CR_LINES" ]; then
  _cr_top5_raw=$(echo "$CR_LINES" | grep -oE 'issue=[0-9]+' | grep -oE '[0-9]+' | sort | uniq -c | sort -rn | head -5 || true)
  if [ -n "$_cr_top5_raw" ]; then
    _cr_top5_parts=""
    while IFS= read -r _cr_line; do
      # Each line from uniq -c is "  COUNT NUMBER" ŌĆö trim leading whitespace
      _cr_count=$(echo "$_cr_line" | awk '{print $1}' || true)
      _cr_issue=$(echo "$_cr_line" | awk '{print $2}' || true)
      if [ -n "$_cr_issue" ] && [ -n "$_cr_count" ]; then
        if [ -n "$_cr_top5_parts" ]; then
          _cr_top5_parts="${_cr_top5_parts}, #${_cr_issue} (${_cr_count}x)"
        else
          _cr_top5_parts="#${_cr_issue} (${_cr_count}x)"
        fi
      fi
    done <<< "$_cr_top5_raw"
    [ -n "$_cr_top5_parts" ] && CR_TOP5_ISSUES="$_cr_top5_parts"
  fi
fi

# --- Pre-compute median resolution duration from CR_LINES ---
# Only lines with duration_s=N (skipped_no_resolver lines have no duration field).
# Median: middle value for odd count; integer average of two middle values for even count.
# Uses a portable while-read sort+count approach (bash 3.2 compatible).
CR_MEDIAN_DURATION_S="N/A"
if [ -n "$CR_LINES" ]; then
  _cr_durations=$(echo "$CR_LINES" | grep -oE 'duration_s=[0-9]+' | grep -oE '[0-9]+' | sort -n || true)
  if [ -n "$_cr_durations" ]; then
    _cr_dur_count=$(echo "$_cr_durations" | wc -l | tr -d ' ' || true)
    if [ "${_cr_dur_count:-0}" -gt 0 ] 2>/dev/null; then
      _cr_mid=$(( (_cr_dur_count + 1) / 2 ))
      _cr_median_val=$(echo "$_cr_durations" | sed -n "${_cr_mid}p" || true)
      # For even counts, average the two middle values
      if [ $(( _cr_dur_count % 2 )) -eq 0 ] 2>/dev/null; then
        _cr_mid2=$(( _cr_mid + 1 ))
        _cr_val2=$(echo "$_cr_durations" | sed -n "${_cr_mid2}p" || true)
        if [ -n "$_cr_median_val" ] && [ -n "$_cr_val2" ]; then
          _cr_median_val=$(( (_cr_median_val + _cr_val2) / 2 ))
        fi
      fi
      [ -n "$_cr_median_val" ] && CR_MEDIAN_DURATION_S="${_cr_median_val}s"
    fi
  fi
fi

# --- Pre-parse test gate stats for health checks ---
# TEST_GATE diag format: "TEST_GATE outcome=passed|failed|skipped lint_count=N test_count=N duration_s=N pr=N"
TG_LINES=$(echo "$DIAG_LINES" | grep 'TEST_GATE ' || true)
TG_TOTAL=$(echo "$TG_LINES" | grep -c 'TEST_GATE ' || true)
TG_PASSED=$(echo "$TG_LINES" | grep -c 'outcome=passed' || true)
TG_FAILED=$(echo "$TG_LINES" | grep -c 'outcome=failed' || true)
TG_SKIPPED=$(echo "$TG_LINES" | grep -c 'outcome=skipped' || true)
# Sum lint and test failure counts across all gate runs
TG_LINT_TOTAL=$(echo "$TG_LINES" | grep -oE 'lint_count=[0-9]+' | grep -oE '[0-9]+' | awk '{sum += $1} END {print sum+0}' || echo "0")
TG_TEST_TOTAL=$(echo "$TG_LINES" | grep -oE 'test_count=[0-9]+' | grep -oE '[0-9]+' | awk '{sum += $1} END {print sum+0}' || echo "0")

# --- Pre-parse test gate selection stats (issue #462) ---
# TEST_GATE_SELECTION diag format: "TEST_GATE_SELECTION mode=targeted|full selected=N total=N pr=N"
TGS_LINES=$(echo "$DIAG_LINES" | grep 'TEST_GATE_SELECTION ' || true)
TGS_TOTAL_RUNS=$(echo "$TGS_LINES" | grep -c 'TEST_GATE_SELECTION ' || true)
TGS_FULL_RUNS=$(echo "$TGS_LINES" | grep -c 'mode=full' || true)
TGS_TARGETED_RUNS=$(echo "$TGS_LINES" | grep -c 'mode=targeted' || true)
# Sum selected + total across targeted runs to compute the avg reduction ratio.
# A reduction ratio < 50% means the optimization is helping; > 50% means too many
# files lack covers headers and the gate keeps falling back to the full path.
TGS_SELECTED_SUM=$(echo "$TGS_LINES" | grep 'mode=targeted' | grep -oE 'selected=[0-9]+' | grep -oE '[0-9]+' | awk '{sum += $1} END {print sum+0}' || echo "0")
TGS_TOTAL_SUM=$(echo "$TGS_LINES" | grep 'mode=targeted' | grep -oE ' total=[0-9]+' | grep -oE '[0-9]+' | awk '{sum += $1} END {print sum+0}' || echo "0")
# Pre-compute the avg selection ratio deterministically ŌĆö arithmetic belongs in
# bash, not the LLM (same principle as CR_TOP5_ISSUES / CR_MEDIAN_DURATION_S).
if [ "${TGS_TOTAL_SUM:-0}" -gt 0 ] 2>/dev/null; then
  TGS_AVG_RATIO_PCT="$(( TGS_SELECTED_SUM * 100 / TGS_TOTAL_SUM ))%"
else
  TGS_AVG_RATIO_PCT="N/A"
fi

# --- Count workflow completions (minimum data gate) ---
WORKFLOW_COUNT=$(echo "$DIAG_LINES" | grep -c 'WORKFLOW_COMPLETE' || true)

if [ "$WORKFLOW_COUNT" -lt "$MIN_WORKFLOWS" ]; then
  {
    echo "# Sharkrite Health Report ŌĆö $TODAY"
    echo ""
    echo "Insufficient data: $WORKFLOW_COUNT workflow completions in the past 7 days (need $MIN_WORKFLOWS+)."
    echo ""
    echo "This report will generate automatically once enough workflows have run with diagnostic logging enabled."
  } > "$REPORT_FILE"
  echo "Insufficient data ($WORKFLOW_COUNT workflows, need $MIN_WORKFLOWS+). Report skipped."
  if [ "$DISPLAY_MODE" = "true" ]; then
    cat "$REPORT_FILE"
  fi
  exit 0
fi

# --- rtk stats (if installed) ---
RTK_STATS=""
if command -v rtk &>/dev/null; then
  RTK_STATS=$(rtk gain --format json 2>/dev/null || echo "rtk gain failed")
fi

# --- Recent sharkrite changes (git log on the tool itself) ---
SHARKRITE_CHANGES=""
if [ -d "$PROJECT_ROOT/.git" ]; then
  SHARKRITE_CHANGES=$(cd "$PROJECT_ROOT" && git log --oneline --since="7 days ago" --stat 2>/dev/null || echo "No recent commits")
fi

# --- Previous reports (last 2 for trend context) ---
PREV_REPORTS=""
prev_files=$(find "$REPORTS_DIR" -name "rite-health-*.md" ! -name "rite-health-${TODAY_COMPACT}.md" 2>/dev/null | sort | tail -2 || true)
for prev_file in $prev_files; do
  PREV_REPORTS+="--- $(basename "$prev_file") ---"$'\n'
  PREV_REPORTS+=$(cat "$prev_file" 2>/dev/null || true)
  PREV_REPORTS+=$'\n\n'
done

# =============================================================================
# Deterministic headline metrics + week-over-week trends
#
# Arithmetic belongs in bash, not the LLM (same principle as CR_TOP5_ISSUES /
# CR_MEDIAN_DURATION_S / TGS_AVG_RATIO_PCT). Each report emits a structured
# <!-- rite-health-metrics {json} --> block (written after generation, below);
# this stage parses the most recent prior report's block to compute exact
# week-over-week deltas. Comparing two exact number sets ŌĆö never parsing the
# prose ŌĆö keeps trend detection reliable. Bootstrap: until Ōēź1 prior report
# carries the block, trends report "baseline" and become available next run.
# =============================================================================

# fix-loop average: mean fix_iterations across WORKFLOW_COMPLETE diag lines
HM_FIXLOOP_AVG=$(echo "$DIAG_LINES" | grep 'WORKFLOW_COMPLETE' | grep -oE 'fix_iterations=[0-9]+' | grep -oE '[0-9]+' \
  | awk '{s+=$1; n++} END {if (n>0) printf "%.2f", s/n; else print "0"}' || echo "0")

# phase-1 (dev) average duration in seconds, parsed from "END phase1_development (Xh Ym Zs)"
HM_PHASE1_AVG_S=$(echo "$TIMING_LINES" | grep 'END   phase1_development' | grep -oE '\([0-9hms ]+\)' \
  | awk '{
      gsub(/[()]/,""); secs=0
      for (i=1;i<=NF;i++){ v=$i
        if (v ~ /h$/){sub(/h/,"",v); secs+=v*3600}
        else if (v ~ /m$/){sub(/m/,"",v); secs+=v*60}
        else if (v ~ /s$/){sub(/s/,"",v); secs+=v} }
      tot+=secs; n++
    } END {if (n>0) printf "%d", tot/n; else print "0"}' || echo "0")

# rtk average savings percent (from rtk gain json)
HM_RTK_PCT=$(echo "$RTK_STATS" | jq -r '(.summary.avg_savings_pct // 0)' 2>/dev/null || echo "0")

# total CRITICAL review findings this week (REVIEW diag lines; correct after #594 severity fix)
HM_CRITICALS=$(echo "$DIAG_LINES" | grep 'REVIEW ' | grep -oE 'critical=[0-9]+' | grep -oE '[0-9]+' \
  | awk '{s+=$1} END {print s+0}' || echo "0")

# Build this week's structured metrics block (emitted into the report below so
# future runs can parse it). Marker is rite-health-metrics (NOT a sharkrite-*
# marker ŌĆö distinct namespace, parsed only here).
HEALTH_METRICS_JSON=$(jq -cn \
  --arg date "$TODAY" \
  --argjson issues "${WORKFLOW_COUNT:-0}" \
  --argjson fixloop "${HM_FIXLOOP_AVG:-0}" \
  --argjson phase1_s "${HM_PHASE1_AVG_S:-0}" \
  --argjson rtk "${HM_RTK_PCT:-0}" \
  --argjson criticals "${HM_CRITICALS:-0}" \
  '{date:$date, issues:$issues, fixloop_avg:$fixloop, phase1_avg_s:$phase1_s, rtk_pct:$rtk, criticals:$criticals}' \
  2>/dev/null || echo '{}')

# Parse the most-recent prior report carrying a structured metrics block
PRIOR_METRICS_JSON=""
for _pf in $(find "$REPORTS_DIR" -name "rite-health-*.md" ! -name "rite-health-${TODAY_COMPACT}.md" 2>/dev/null | sort -r); do
  _blk=$(sed -n '/<!-- rite-health-metrics/,/-->/p' "$_pf" 2>/dev/null | sed '1d;$d' || true)
  if [ -n "$_blk" ] && echo "$_blk" | jq -e . >/dev/null 2>&1; then
    PRIOR_METRICS_JSON="$_blk"
    break
  fi
done

# Compose beforeŌåÆafter trend pairs (exact numbers; the prompt characterizes
# direction since "is up good or bad" differs per metric).
if [ -n "$PRIOR_METRICS_JSON" ]; then
  _pd=$(echo "$PRIOR_METRICS_JSON" | jq -r '.date // "?"')
  TREND_PAIRS="(vs $_pd)
- issues completed: $(echo "$PRIOR_METRICS_JSON" | jq -r '.issues // "?"') ŌåÆ ${WORKFLOW_COUNT}
- fix-loop avg: $(echo "$PRIOR_METRICS_JSON" | jq -r '.fixloop_avg // "?"') ŌåÆ ${HM_FIXLOOP_AVG}
- phase-1 avg (s): $(echo "$PRIOR_METRICS_JSON" | jq -r '.phase1_avg_s // "?"') ŌåÆ ${HM_PHASE1_AVG_S}
- rtk savings %: $(echo "$PRIOR_METRICS_JSON" | jq -r '.rtk_pct // "?"') ŌåÆ ${HM_RTK_PCT}
- CRITICAL findings: $(echo "$PRIOR_METRICS_JSON" | jq -r '.criticals // "?"') ŌåÆ ${HM_CRITICALS}"
else
  TREND_PAIRS="(no prior structured metrics block found ŌĆö this is the baseline week; week-over-week trends become available once this report's metrics block is on disk for next run)"
fi

# =============================================================================
# Stage 2: Build prompt and invoke Claude
# =============================================================================

PROMPT_FILE=$(mktemp)
trap 'rm -f "$PROMPT_FILE"' EXIT

cat > "$PROMPT_FILE" << 'SYSTEM_PROMPT'
You are an operational analyst for Sharkrite, an AI-powered GitHub workflow automation CLI. You are generating a weekly health report based on diagnostic log data.

## Your Task

Analyze the provided data and produce a concise markdown health report. Be direct and actionable. No fluff.

## Report Sections

0. **TL;DR** ŌĆö the FIRST section, written for a 10-second skim by a busy operator with zero knowledge of diag-line internals. Exactly these three bullets, in plain English (no jargon like "diag", "phase3", "TGS"):
   - **Status:** one of `Ō£ģ Healthy`, `ŌÜĀ’ĖÅ Needs attention`, or `­¤ö┤ Action required` ŌĆö pick from the worst threshold tripped below.
   - **The number that matters:** the single most important stat this week, stated like a human would ("Merged 21 of 24 issues cleanly; 2 needed a fix pass" ŌĆö not "fix_iterations avg=0.2").
   - **Do this:** the ONE most important action for the operator, or "Nothing ŌĆö everything's healthy" if no threshold tripped.
1. **At a Glance** ŌĆö a compact stat line of the key numbers IF they exist (omit any that are zero/absent): issues merged, fix-loop avg, phase-1 avg, rtk savings %, gate pass rate, CRITICALs. One line, pipe-separated. Skip entirely if there's no data.
2. **Trends** (FOREGROUNDED ŌĆö this is the headline of the report) ŌĆö use the pre-computed TREND_PAIRS block (exact this-week-vs-prior numbers; do NOT parse the prose of prior reports). For each metric, state the direction and whether it's good or bad FOR THAT METRIC (e.g. fix-loop Ōåō = good; CRITICALs Ōåæ = bad; rtk% Ōåō = watch; phase-1 Ōåæ = watch). One bullet per metric that changed; lead with the most significant movement. Call out velocity, not just level ("fix-loop doubled week-over-week, still under the 2.0 line" is more useful than the absolute alone). If TREND_PAIRS says baseline week, say so in one line and move on ŌĆö do not fabricate trends. Trends AUGMENT the absolute Health Checks below; they do not replace them.
3. **Summary** ŌĆö 2-3 plain-English sentences expanding the TL;DR. Write for a human reader, not a log parser.
4. **Metrics** ŌĆö Issues processed, token savings (if rtk active), fix loop iterations, phase durations
5. **Health Checks** ŌĆö Absolute thresholds, KEPT alongside the Trends section above (trends catch direction; these catch "bad right now" regardless of direction). Flag anything concerning:
   - Fix iterations avg > 2.0 ŌåÆ WARNING
   - Any phase failing > 30% of the time ŌåÆ WARNING
   - Phase 1 (dev) duration avg > 20 min ŌåÆ WATCH
   - rtk savings < 30% avg ŌåÆ WATCH (possible over-compression)
   - Any issue hitting max fix iterations (3) ŌåÆ flag that specific issue
   - Review finding 0 issues consistently ŌåÆ WATCH (review prompt may be too lenient)
   - CRITICAL findings appearing ŌåÆ flag
6. **Test Gate** ŌĆö Summarize post-commit verification gate stats using the pre-parsed stats provided:
   - Show: Total gate runs, outcome breakdown (passed/failed/skipped), lint failures total, bats test failures total
   - Thresholds:
     - gate failure rate > 30% ŌåÆ **WARNING**: "Fix sessions introducing regressions frequently"
     - `skipped` > 0 ŌåÆ **WATCH**: "Gate skipped (bats/make missing on some runners)"
     - TG_LINT_TOTAL > 0 ŌåÆ flag which fix iterations introduced lint violations
   - If TG_TOTAL is 0, say "No post-commit gate runs recorded this week (feature new or gate not yet active)."
   - **Test Selection** (issue #462) sub-section: report from TGS_* stats provided:
     - Show: total gate invocations, targeted-vs-full breakdown, average targeted-selection ratio (use TGS_AVG_RATIO_PCT directly ŌĆö do not recompute)
     - Threshold: if targeted runs exist and the avg selected/total ratio > 50% ŌåÆ **WATCH**: "Test selection ratio is high ŌĆö most bats files lack the ${RITE_MARKER_TEST_COVERS}: header; backfill more to realize the optimization."
     - If TGS_TARGETED_RUNS is 0 but TGS_FULL_RUNS > 0 ŌåÆ "All gate runs fell back to the full suite this week (no diff computable ŌĆö empty-diff fallback; path triggers were removed 2026-06-12)."
     - If TGS_TOTAL_RUNS is 0 ŌåÆ "No selection data this week."
7. **Conflict Resolver** ŌĆö Summarize conflict resolution attempts using the pre-parsed stats provided:
   - Show: Total invocations, outcome breakdown (resolved/failed/cap_hit/skipped_no_resolver), most affected issues (use CR_TOP5_ISSUES directly ŌĆö do not recompute), median resolution duration (use CR_MEDIAN_DURATION_S directly ŌĆö do not recompute)
   - Thresholds:
     - `skipped_no_resolver` > 0 ŌåÆ **WARNING**: "Resolver not wired ŌĆö conflict-resolver.sh may be missing"
     - failure rate > 30% ŌåÆ **WATCH**: "Resolver failing frequently"
   - If CR_TOTAL is 0, say "No conflict resolution attempts this week."
8. **Sharkrite Changes** ŌĆö If tool code changed this week, note which subsystems were modified. Correlate with any metric shifts (e.g., "assess-and-resolve.sh modified 3 days ago; Phase 3 metrics show no degradation ŌĆö change appears safe"). If no changes, say "No tool changes this week."
9. **Insights** ŌĆö Correlate, don't just observe. Explicitly connect the Sharkrite Changes to metric shifts in the Trends section: name the file/subsystem that changed and the metric that moved in the same window, and say whether the change is the likely cause (e.g. "assess-and-resolve.sh changed 2 days ago; fix-loop avg rose 0.2ŌåÆ0.6 the same window ŌĆö likely related, worth a look" or "Phase-1 up but no dev-path code changed ŌĆö probably load, not a regression"). Cross-reference previous reports: are previously flagged issues improving or persisting? Prefer a stated causal hypothesis (grounded in the data) over a bare observation.
10. **Action Items** ŌĆö Specific, actionable recommendations. Examples:
   - "Consider adding `gh pr diff` to rtk exclude list ŌĆö Phase 3 fix iterations up"
   - "Phase 1 duration trending down ŌĆö rtk compression appears effective"
   - "Review severity skewing toward LOW ŌĆö tighten review prompt for more meaningful findings"
   If everything looks healthy, say "No action needed ŌĆö continue monitoring."

## Data Format

- `[diag]` lines are structured: `WORKFLOW_COMPLETE`, `ASSESSMENT`, `REVIEW`, `PHASE_FAILED`, `SESSION`, `CONFLICT_RESOLVER`, `TEST_GATE`
- `[timing]` lines show phase durations: `END phase_name (Xm Xs)`
- rtk stats are JSON from `rtk gain --format json`
- Git log shows recent tool changes with file stats
- Previous reports provide trend context
- Pre-parsed conflict resolver stats: CR_TOTAL, CR_RESOLVED, CR_FAILED, CR_CAP_HIT, CR_SKIPPED (counts); CR_TOP5_ISSUES (formatted string); CR_MEDIAN_DURATION_S (formatted string, e.g. "45s" or "N/A")
- Pre-parsed test gate stats: TG_TOTAL, TG_PASSED, TG_FAILED, TG_SKIPPED, TG_LINT_TOTAL, TG_TEST_TOTAL (counts)
- Pre-parsed test gate selection stats: TGS_TOTAL_RUNS, TGS_TARGETED_RUNS, TGS_FULL_RUNS, TGS_SELECTED_SUM, TGS_TOTAL_SUM (counts)

## Constraints

- Output ONLY the markdown report. No preamble, no explanation of your process.
- Keep it scannable ŌĆö use bullet points, not paragraphs.
- Be specific when flagging issues (mention issue numbers, phase names, exact metrics).
- If data is sparse for a section, say so briefly and move on.
SYSTEM_PROMPT

cat >> "$PROMPT_FILE" << DATABLOCK

---

## Diagnostic Log Lines (past 7 days)

$DIAG_LINES

## Phase Timing Lines (past 7 days)

$TIMING_LINES

## Test Gate Stats (pre-parsed, past 7 days)

- TG_TOTAL (total gate runs): $TG_TOTAL
