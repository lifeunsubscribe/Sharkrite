#!/bin/bash
# bin/rite-full-suite — Full-suite safety net runner
#
# Runs the unfiltered test suite (make check + bats -r tests/) against the
# current branch, bypassing the targeted-selection logic in test-gate.sh.
# This is the periodic safety net that catches drift between bats covers
# headers and the code they actually exercise.
#
# See: docs/architecture/behavioral-design.md → "Test Selection by Changed Paths"
# Motivating issue: #482 (periodic full-suite safety net)
#
# Usage:
#   rite --full-suite               # Run via the rite dispatcher
#   bin/rite-full-suite             # Direct invocation (same effect)
#
# Exit codes:
#   0  — all checks and tests passed
#   1  — one or more failures (lint or bats)
#
# Diag emitted:
#   [diag] FULL_SUITE_RUN outcome=passed|failed lint_count=N test_count=N duration_s=N
#
# State written on failure:
#   .rite/state/full-suite-failure.flag  (deleted on next successful run)
#
# Log written:
#   .rite/logs/full-suite-YYYYMMDD.log

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RITE_INSTALL_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
RITE_LIB_DIR="$RITE_INSTALL_DIR/lib"
export RITE_INSTALL_DIR RITE_LIB_DIR

# Source config (detects project root, RITE_DATA_DIR, etc.)
source "$RITE_LIB_DIR/utils/config.sh"
source "$RITE_LIB_DIR/utils/colors.sh"
source "$RITE_LIB_DIR/utils/logging.sh"

# Force verbose off: when RITE_VERBOSE=true is inherited, _diag() writes to
# stderr (which is torn down after the tee reader exits) instead of
# RITE_LOG_FILE — the FULL_SUITE_RUN diag line would be lost.
# Per the two-channel convention, structured diag lines must land in the log.
RITE_VERBOSE=false
export RITE_VERBOSE

# ---------------------------------------------------------------------------
# Resolve project root and state paths
# ---------------------------------------------------------------------------
_PROJECT_ROOT="${RITE_PROJECT_ROOT:-$(pwd)}"
_DATA_DIR="${RITE_DATA_DIR:-.rite}"
_LOGS_DIR="$_PROJECT_ROOT/$_DATA_DIR/logs"
_STATE_DIR="$_PROJECT_ROOT/$_DATA_DIR/state"
_FAILURE_FLAG="$_STATE_DIR/full-suite-failure.flag"

mkdir -p "$_LOGS_DIR" "$_STATE_DIR"

# ---------------------------------------------------------------------------
# Log file setup: append a header + tee output
# ---------------------------------------------------------------------------
_TODAY=$(date '+%Y-%m-%d')
_TODAY_COMPACT=$(date '+%Y%m%d')
_LOG_FILE="$_LOGS_DIR/full-suite-${_TODAY_COMPACT}.log"
_HOSTNAME=$(hostname -s 2>/dev/null || echo "unknown")
_BRANCH=$(git -C "$_PROJECT_ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")

{
  echo "=== Sharkrite Full-Suite Run ==="
  echo "Date:   $_TODAY $(date '+%H:%M:%S')"
  echo "Host:   $_HOSTNAME"
  echo "Branch: $_BRANCH"
  echo "==="
  echo ""
} >> "$_LOG_FILE"

# Set RITE_LOG_FILE so _diag() writes structured lines to the run log.
export RITE_LOG_FILE="$_LOG_FILE"

# Tee all output (stdout+stderr merged) to the log for a full transcript, using
# the same pattern as bin/rite (lib/.. → bin/rite:446). strip_ansi strips color
# codes so the on-disk transcript is plain text.
#
# Do NOT reintroduce a named FIFO + a pre-exit `wait` on the reader here. That
# deadlocks: with `exec > >(tee fifo)` bash keeps the process-substitution write
# fd open until the shell *exits*, so the reader never sees EOF and a `wait`
# placed before exit hangs forever — in every context, including the weekly cron
# run (and it hangs bats' `run`/`$()` output capture). The structured
# FULL_SUITE_RUN diag and the failure flag are written directly to the log/state
# via `>>`, so they are immune to any tee-flush truncation at exit.
_lint_raw=""
_lint_raw_stripped=""
_tests_raw=""
trap 'rm -f "${_lint_raw:-}" "${_lint_raw_stripped:-}" "${_tests_raw:-}"' EXIT

exec > >(tee >(strip_ansi >> "$_LOG_FILE"))
exec 2>&1

print_header "Sharkrite Full-Suite Safety Net"
print_info "Project: ${RITE_PROJECT_NAME:-unknown}"
print_info "Branch:  $_BRANCH"
print_info "Log:     $_LOG_FILE"
echo ""

# ---------------------------------------------------------------------------
# Pre-flight: check required tools
# ---------------------------------------------------------------------------
if ! command -v make >/dev/null 2>&1; then
  print_error "make not found — cannot run lint check"
  exit 1
fi
if ! command -v bats >/dev/null 2>&1; then
  print_error "bats not found — cannot run test suite"
  exit 1
fi

# Verify this is a Sharkrite repo (has shellcheck: and lint: Makefile targets).
if ! (grep -q "^shellcheck:" "$_PROJECT_ROOT/Makefile" 2>/dev/null \
      && grep -q "^lint:" "$_PROJECT_ROOT/Makefile" 2>/dev/null); then
  print_warning "Makefile missing shellcheck: or lint: targets — not a Sharkrite repo?"
  print_info "Proceeding anyway with 'make check' and 'bats -r tests/'"
fi

# ---------------------------------------------------------------------------
# Run make check (lint gate — full scan, no targeted selection)
# ---------------------------------------------------------------------------
_start=$(date +%s)
_lint_exit=0
_lint_count=0

print_step "Running make check (full lint scan)..."
# _lint_raw is assigned here (was pre-initialized empty for the EXIT trap above)
_lint_raw=$(mktemp "${TMPDIR:-/tmp}/rite_fs_lint_$$_XXXXXX")

set +e
(cd "$_PROJECT_ROOT" && make check) 2>&1 | tee "$_lint_raw"
_lint_exit=${PIPESTATUS[0]}
set -e

if [ "$_lint_exit" -ne 0 ]; then
  print_warning "Lint check failed (exit $_lint_exit)"

  # Strip ANSI escape sequences before counting. make check may emit colorized
  # output (e.g. shellcheck with --color=always or a terminal-aware make), which
  # would prepend \x1b[...m bytes to lines and break the ^[^:]+ file-path
  # anchors below. Use perl (not sed) — BSD sed on macOS does not support \x1b
  # or hex character ranges like [\x01-\x08], causing "RE error: invalid
  # character range" and producing an empty stripped file under || true. perl
  # ships on all target platforms (macOS system perl, all Linux distros) and
  # handles \x.. escapes consistently. Three passes: (1) CSI sequences
  # \e[...m, (2) bare ESC bytes, (3) remaining C0 control bytes (tab \x09
  # is left intact). The stripped copy is used for both count and failure-flag
  # extraction so the transformation runs exactly once.
  _lint_raw_stripped=$(mktemp "${TMPDIR:-/tmp}/rite_fs_lint_stripped_$$_XXXXXX")
  perl -pe 's/\x1b\[[0-9;]*[a-zA-Z]//g; s/\x1b//g; s/[\x01-\x08\x0b-\x0c\x0e-\x1f\x7f]//g' \
    "$_lint_raw" > "$_lint_raw_stripped" || true

  # Count lines matching known lint output formats.
  # Lines from the linters look like:
  #   from shellcheck:     file:line:col: [SCnnnn] message
  #   from sharkrite-lint: file:line: [RULE_NAME] message
  # Both patterns are covered below. If neither matches (unexpected format),
  # fall back to a non-zero sentinel (1) so failure-flag detail is still
  # written — a count of 0 with outcome=failed is a self-contradicting signal.
  _lint_count=$(grep -cE '^[^:]+:[0-9]+:[0-9]+:[[:space:]]*\[SC[0-9]+\]|^[^:]+:[0-9]+:[[:space:]]*\[[A-Z_]+\]' "$_lint_raw_stripped" || true)
  if [ "${_lint_count:-0}" -eq 0 ]; then
    # No lines matched the structured format; use a sentinel of 1 so the
    # failure flag records that lint violations exist (exact count unknown).
    _lint_count=1
  fi
else
  print_success "Lint check passed"
fi
echo ""

# ---------------------------------------------------------------------------
# Run bats -r tests/ (full suite — no targeted selection, no FORCE_FULL check)
# ---------------------------------------------------------------------------
_tests_exit=0
_tests_count=0

print_step "Running bats -r tests/ (full suite, no targeted selection)..."
# _tests_raw is assigned here (was pre-initialized empty for the EXIT trap above)
_tests_raw=$(mktemp "${TMPDIR:-/tmp}/rite_fs_tests_$$_XXXXXX")

# Detect bats parallelism (mirrors _compute_bats_jobs from test-gate.sh).
# RITE_BATS_JOBS must be a positive integer; non-integer values (e.g. "auto")
# would cause [ ... -gt 1 ] to abort under set -e with "integer expression
# expected". Apply the same ^[1-9][0-9]*$ sanitization as test-gate.sh does.
_bats_jobs=1
if command -v parallel >/dev/null 2>&1 || command -v rush >/dev/null 2>&1; then
  _bats_jobs=$(sysctl -n hw.ncpu 2>/dev/null || nproc 2>/dev/null || echo "2")
fi
if [ -n "${RITE_BATS_JOBS:-}" ]; then
  if echo "${RITE_BATS_JOBS}" | grep -qE '^[1-9][0-9]*$'; then
    _bats_jobs="${RITE_BATS_JOBS}"
  fi
  # Non-integer value → fall through to auto-detected _bats_jobs (silent, like test-gate.sh)
fi

_total_bats=$(cd "$_PROJECT_ROOT" && find tests -name "*.bats" -type f 2>/dev/null | wc -l | tr -d ' ' || echo "0")
print_info "Running $_total_bats bats files (parallel jobs: $_bats_jobs)"

set +e
if [ "${_bats_jobs:-1}" -gt 1 ]; then
  (cd "$_PROJECT_ROOT" && bats --jobs "$_bats_jobs" -r tests/) 2>&1 | tee "$_tests_raw"
else
  (cd "$_PROJECT_ROOT" && bats -r tests/) 2>&1 | tee "$_tests_raw"
fi
_tests_exit=${PIPESTATUS[0]}
set -e

_tests_count=$(grep -c "^not ok " "$_tests_raw" || true)

if [ "$_tests_exit" -ne 0 ]; then
  print_warning "Test suite failed ($_tests_count test failure(s))"
else
  print_success "Test suite passed"
fi
echo ""

# ---------------------------------------------------------------------------
# Determine outcome + emit diag
# ---------------------------------------------------------------------------
_end=$(date +%s)
_duration=$(( _end - _start ))
_overall_exit=0
_outcome="passed"

if [ "$_lint_exit" -ne 0 ] || [ "$_tests_exit" -ne 0 ]; then
  _overall_exit=1
  _outcome="failed"
fi

# Emit structured diag for health-report aggregation.
# Writes directly to RITE_LOG_FILE (two-channel convention — not via stdout).
_diag "FULL_SUITE_RUN outcome=${_outcome} lint_count=${_lint_count} test_count=${_tests_count} duration_s=${_duration}"

# ---------------------------------------------------------------------------
# Manage failure flag
# ---------------------------------------------------------------------------
if [ "$_outcome" = "failed" ]; then
  # Write failure flag listing failing tests and lint count
  {
    echo "# Sharkrite full-suite failure flag"
    echo "# Written: $(date '+%Y-%m-%d %H:%M:%S')"
    echo "# Branch:  $_BRANCH"
    echo "outcome=failed"
    echo "lint_count=${_lint_count}"
    echo "test_count=${_tests_count}"
    echo "duration_s=${_duration}"
    echo "log=${_LOG_FILE}"
    if [ "$_tests_count" -gt 0 ]; then
      echo ""
      echo "# Failing tests:"
      grep "^not ok " "$_tests_raw" 2>/dev/null | sed 's/^not ok [0-9]* /  /' || true
    fi
    if [ "$_lint_count" -gt 0 ]; then
      echo ""
      echo "# Lint violations ($_lint_count):"
      # Use the ANSI-stripped copy so violation lines in the flag are plain text.
      grep -E '^[^:]+:[0-9]+:[0-9]+:[[:space:]]*\[SC[0-9]+\]|^[^:]+:[0-9]+:[[:space:]]*\[[A-Z_]+\]' "${_lint_raw_stripped:-$_lint_raw}" 2>/dev/null \
        | head -20 | sed 's/^/  /' || true
    fi
  } > "$_FAILURE_FLAG"
  print_error "Full suite FAILED — failure flag written: $_FAILURE_FLAG"
  print_info "Run 'rite --status' to see the failure banner"
else
  # Delete the flag on success so the banner clears
  rm -f "$_FAILURE_FLAG"
  print_success "Full suite passed in ${_duration}s (lint: 0 violations, tests: $_total_bats files)"
fi

rm -f "${_lint_raw:-}" "${_tests_raw:-}"
exit "$_overall_exit"
