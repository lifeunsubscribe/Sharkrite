#!/usr/bin/env bash
# rite - Sharkrite CLI for automated GitHub workflows
# Smart dispatcher that routes to appropriate workflow
#
# Usage:
#   rite <issue>                  Full lifecycle (default)
#   rite <issue> --dev-and-pr     Dev + PR only, skip review/merge
#   rite <issue> --review-latest  Generate and post review
#   rite <issue> --assess-and-fix Assess review + fix loop
#   rite <issue> --status         Read-only workflow state overview
#   rite <issue> --undo           Undo: close PR, cleanup
#   rite --status                 Repo-wide status overview
#   rite --status --by-label      Repo-wide status grouped by label
#   rite --tags                   Show tag index (--tags <tag> | --orphans | --history)
#   rite plan [doc] [instructions] Generate issues from architectural docs
#   rite --init                   Initialize .rite/ in current project
#   rite --backfill-locks         Backfill issue lock files for legacy worktrees
#   rite --full-suite             Run unfiltered make check + bats -r tests/
#   rite --dry-run <...>          Print execution plan without running

set -euo pipefail

VERSION="2.0.0"

# Resolve symlink chain to get actual install location
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_PATH" ]; do
  SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ $SCRIPT_PATH != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
RITE_INSTALL_DIR="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
RITE_LIB_DIR="$RITE_INSTALL_DIR/lib"
export RITE_INSTALL_DIR RITE_LIB_DIR

# Parse --dry-run early (before config, so config respects it)
for arg in "$@"; do
  if [ "$arg" = "--dry-run" ]; then
    export RITE_DRY_RUN=true
  fi
done

# Source configuration (detects project, loads configs)
source "$RITE_LIB_DIR/utils/config.sh"
source "$RITE_LIB_DIR/utils/colors.sh"
# Source portable command wrappers (sed -i — BSD/GNU compat)
source "$RITE_LIB_DIR/utils/portable-cmds.sh"
# Source gh retry wrapper for resilient GitHub API calls
source "$RITE_LIB_DIR/utils/gh-retry.sh"
# Source marker constants
source "$RITE_LIB_DIR/utils/markers.sh"

# Default mode: full lifecycle (workflow-runner)
MODE="full"
RITE_LOG_FILE="${RITE_LOG_FILE:-}"
RITE_LOG_AUTO=true  # Logging on by default

# Parse args and detect intent
ARGS=()
WORKFLOW_FLAGS=()
LABEL_FILTER=""
BATCH_FILTER_ARGS=()
SUPERVISED=false
SYNC_BRANCH_ARG=""  # set when SYNC_ARGS contains exactly one non-numeric arg (branch form)
SYNC_ARGS=()        # all post-sync args; typed dispatch sets SYNC_MODE from these
SYNC_MODE=""        # "branch" | "issue" | "all" — resolved from SYNC_ARGS at parse time
while [[ $# -gt 0 ]]; do
  case $1 in
    --dev-and-pr)
      MODE="dev-and-pr"
      shift
      ;;
    --review-latest)
      MODE="review-latest"
      shift
      ;;
    --assess-and-fix)
      MODE="assess-and-fix"
      shift
      ;;
    --status)
      MODE="status"
      shift
      ;;
    --undo)
      MODE="undo"
      shift
      ;;
    --reset-approval)
      MODE="reset-approval"
      shift
      ;;
    --backfill-locks)
      MODE="backfill-locks"
      shift
      ;;
    --tags)
      MODE="tags"
      shift
      # Collect the optional sub-arg: <tag>, --orphans, or --history
      # Stop consuming args after the first non-flag or recognized sub-flag.
      TAGS_SUBARG=""
      if [ "${1:-}" = "--orphans" ] || [ "${1:-}" = "--history" ]; then
        TAGS_SUBARG="$1"
        shift
      elif [ -n "${1:-}" ] && [[ "$1" != -* ]]; then
        TAGS_SUBARG="$1"
        shift
      fi
      ;;
    --health-report|--rtk-report)
      MODE="health-report"
      shift
      ;;
    --full-suite)
      MODE="full-suite"
      shift
      ;;
    --sync)
      # Sync verb: typed dispatch based on remaining args.
      #   zero args       → all-repo form (sweep ledger branches + in-flight worktrees)
      #   one non-numeric → branch form (merge origin/main into integration branch)
      #   one or more all-digits → issue form (rebase each feature branch onto its base)
      #   mixed or multi-branch  → usage error
      MODE="sync"
      shift
      # Collect all remaining non-flag args as sync args
      while [[ $# -gt 0 ]] && [[ "$1" != -* ]]; do
        SYNC_ARGS+=("$1")
        shift
      done
      ;;
    --refresh-encountered-issues)
      MODE="refresh-encountered-issues"
      shift
      ;;
    --supervised)
      SUPERVISED=true
      export RITE_VERBOSE="${RITE_VERBOSE:-true}"  # supervised implies verbose
      export RITE_SUPERVISED=true                  # propagated to batch-process-issues.sh via env
      WORKFLOW_FLAGS+=("--supervised")
      shift
      ;;
    --auto)
      WORKFLOW_FLAGS+=("--auto")
      shift
      ;;
    --bypass-blockers)
      WORKFLOW_FLAGS+=("--bypass-blockers")
      shift
      ;;
    --allow-main-base)
      WORKFLOW_FLAGS+=("--allow-main-base")
      shift
      ;;
    --by-label|--group-by-label)
      LABEL_FILTER="--by-label"
      shift
      ;;
    --label)
      BATCH_FILTER_ARGS=("--label" "$2")
      shift 2
      ;;
    --log)
      RITE_LOG_AUTO=true  # Explicit enable (already default, here for clarity)
      shift
      ;;
    --no-log)
      RITE_LOG_AUTO=false
      shift
      ;;
    --verbose)
      export RITE_VERBOSE=true
      shift
      ;;
    --log=*)
      RITE_LOG_FILE="${1#--log=}"
      shift
      ;;
    --pr)
      # Run by PR number instead of issue number
      if [ -z "${2:-}" ] || [[ "$2" == -* ]]; then
        print_error "--pr requires a PR number"
        exit 1
      fi
      PR_INPUT="$2"
      shift 2
      ;;
    --branch)
      # Set target integration branch (default: main); consumed by follow-on issues
      if [ -z "${2:-}" ] || [[ "$2" == -* ]]; then
        print_error "--branch requires a branch name"
        exit 1
      fi
      if [[ "$2" == *[[:space:]]* ]]; then
        print_error "--branch value must not contain whitespace"
        exit 1
      fi
      export RITE_TARGET_BRANCH="$2"
      # Also thread target explicitly via workflow-runner.sh's --base arm so the
      # single-issue execs carry it without relying solely on the env export.
      # (doc §3.2: single-issue dispatch exercises the --base parser arm)
      WORKFLOW_FLAGS+=("--base" "$2")
      shift 2
      ;;
    --dry-run)
      # Already parsed above
      shift
      ;;
    --init)
      MODE="init"
      shift
      ;;
    --no-backfill-adrs)
      export RITE_NO_BACKFILL_ADRS=true
      shift
      ;;
    --backfill-count)
      if [ -z "${2:-}" ] || [[ "$2" == -* ]]; then
        print_error "--backfill-count requires a number"
        exit 1
      fi
      export RITE_BACKFILL_ADR_COUNT="$2"
      shift 2
      ;;
    plan)
      MODE="plan"
      shift
      # Collect remaining args for plan (doc paths + natural language)
      PLAN_ARGS=("$@")
      shift $#
      ;;
    --version|-v)
      echo "rite version $VERSION"
      exit 0
      ;;
    --help|-h)
      echo "rite - Sharkrite CLI v${VERSION}"
      echo "Automate GitHub issues with Claude Code"
      echo ""
      echo "Usage:"
      echo "  rite <issue>                  Process single issue (unsupervised, default)"
      echo "  rite \"<description>\"          Generate a structured issue from free text, then run it"
      echo "  rite <issue> --supervised     Process single issue (supervised mode)"
      echo "  rite <issue1> <issue2>        Process multiple issues (batch)"
      echo "  rite --label tech-debt        Process all open issues with label (batch)"
      echo "  rite <issue> --dev-and-pr     Dev + PR only, skip review/merge"
      echo "  rite <issue> --review-latest  Generate and post review for latest code"
      echo "  rite <issue> --assess-and-fix Assess review + fix loop"
      echo "  rite <issue> --status         Show workflow status for an issue"
      echo "  rite --status                 Repo-wide status overview"
      echo "  rite --status --by-label      Repo-wide status grouped by label"
      echo "  rite <issue> --undo           Undo workflow: close PR, clean up artifacts"
      echo "  rite <issue> --reset-approval Clear saved blocker approvals for an issue"
      echo "  rite --reset-approval         Clear ALL saved blocker approvals (global reset)"
      echo "  rite plan [doc] [instructions] Generate issues from an architectural doc"
      echo "  rite plan --preview [doc]     Preview issues without creating them"
      echo "  rite --pr <number>            Run by PR number (creates issue if none linked)"
      echo "  rite --init                   Initialize .rite/ in current project"
      echo "  rite --init --no-backfill-adrs Skip ADR backfill during init"
      echo "  rite --init --backfill-count N Backfill N ADRs (default: 5)"
      echo "  rite --backfill-locks         Backfill issue lock files for legacy worktrees"
      echo "  rite --refresh-encountered-issues  Refresh docs/architecture/encountered-issues.md"
      echo "  rite --sync <branch>          Git hygiene: merge origin/main into an integration branch (explicit, never automatic)"
      echo "  rite --sync N [M ...]         Git hygiene: rebase feature branch(es) for issue(s) onto their resolver-determined base (rebase rewrites SHAs — review goes stale by design)"
      echo "  rite --sync                   # Git hygiene: sweep all ledger integration branches then all in-flight worktrees"
      echo "  rite --full-suite             Run unfiltered make check + bats -r tests/ (periodic safety net)"
      echo "  rite --tags                   Show full tag index"
      echo "  rite --tags <tag>             Show pointers for a specific tag"
      echo "  rite --tags --orphans         Show catalog entries with no tag pointers"
      echo "  rite --tags --history         Show tag merge history (stub)"
      echo "  rite --dry-run <...>          Print execution plan without running"
      echo "  rite <issue> --no-log         Full lifecycle without logging (logs are on by default)"
      echo ""
      echo "Workflow flags:"
      echo "  --supervised               Supervised mode (approve hard gates interactively)"
      echo "  --bypass-blockers          Skip hard gates in unsupervised mode (CRITICAL findings, session limits)"
      echo "  --allow-main-base          Allow merging a main-based PR when session target is non-main (overrides integration-branch guard)"
      echo "  --branch <name>            Target integration branch (default: main; inert until #1033)"
      echo "  --no-log                   Disable logging (logs are on by default)"
      echo "  --verbose                  Show extra detail (branch cleanup explanations, etc.)"
      echo "  --log=FILE                 Log to a specific file instead of auto-generated path"
      echo ""
      echo "Phase commands (run individual workflow phases):"
      echo "  --dev-and-pr               Dev + PR only, skip review/merge"
      echo "  --review-latest            Generate and post review for latest code"
      echo "  --assess-and-fix           Assess review findings + fix loop (up to 3 retries)"
      echo "  --status                   Show workflow status (per-issue or repo-wide)"
      echo "  --by-label                 Group repo-wide status by label"
      echo ""
      echo "Project: $RITE_PROJECT_NAME"
      echo "Root:    $RITE_PROJECT_ROOT"
      echo "Config:  $RITE_PROJECT_ROOT/$RITE_DATA_DIR/config"
      echo ""
      echo "Examples:"
      echo "  rite 21                    # Full lifecycle (unsupervised, default)"
      echo "  rite 21 --supervised       # Supervised: approve hard gates interactively"
      echo "  rite 21 --bypass-blockers  # Skip hard gates (CRITICAL findings, session limits)"
      echo "  rite 21 45                 # Batch process issues"
      echo "  rite 21 --dev-and-pr       # Dev + PR only (skip review/merge)"
      echo "  rite 21 --review-latest    # Generate and post review"
      echo "  rite 21 --assess-and-fix   # Assess review + fix loop"
      echo "  rite 21 --status           # Show workflow status"
      echo "  rite 21 --undo             # Undo: close PR, clean branches/worktree/state"
      echo "  rite 21 --reset-approval   # Clear saved blocker approvals for issue 21"
      echo "  rite --reset-approval      # Clear ALL saved blocker approvals"
      echo "  rite --pr 72               # Run by PR number (orphan PRs handled automatically)"
      echo "  rite plan docs/phases.md   # Generate issues from doc"
      echo "  rite plan \"phases 2-4\"     # Natural language filtering"
      echo "  rite plan --preview        # Preview without creating"
      echo "  rite --status              # Repo-wide status overview"
      echo "  rite --status --by-label   # Status grouped by label"
      echo "  rite 21 --dry-run          # See what would happen"
      echo ""
      echo "Sharkrite - Master your workflows."
      exit 0
      ;;
    -*)
      print_error "Unknown flag: $1"
      exit 1
      ;;
    # Bare-word aliases for flag-subcommand words: e.g. `rite status` → `rite --status`.
    # Without these, the `*)` catch-all below would add the word to ARGS and, with
    # MODE="full", route it to issue-generation — burning an LLM call and potentially
    # creating a junk issue from a typo.  Map every recognised subcommand word to its
    # MODE here, mirroring the --flag cases above.  `plan` already has its own bare
    # case higher up.
    status)
      MODE="status"
      shift
      ;;
    health-report|rtk-report)
      MODE="health-report"
      shift
      ;;
    init)
      MODE="init"
      shift
      ;;
    tags)
      MODE="tags"
      shift
      # Collect the optional sub-arg: <tag>, --orphans, or --history
      # (mirrors the --tags case above)
      TAGS_SUBARG=""
      if [ "${1:-}" = "--orphans" ] || [ "${1:-}" = "--history" ]; then
        TAGS_SUBARG="$1"
        shift
      elif [ -n "${1:-}" ] && [[ "$1" != -* ]]; then
        TAGS_SUBARG="$1"
        shift
      fi
      ;;
    full-suite)
      MODE="full-suite"
      shift
      ;;
    sync)
      # Bare-word alias: `rite sync [args...]` → `rite --sync [args...]`.
      # Mirrors the --sync flag case above: collect zero-or-more non-flag args,
      # typed dispatch resolves the form (all-repo / issue / branch) later.
      MODE="sync"
      shift
      while [[ $# -gt 0 ]] && [[ "$1" != -* ]]; do
        SYNC_ARGS+=("$1")
        shift
      done
      ;;
    backfill-locks)
      MODE="backfill-locks"
      shift
      ;;
    refresh-encountered-issues)
      MODE="refresh-encountered-issues"
      shift
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

# --- Sync arg-type resolution -------------------------------------------------
# Resolve SYNC_ARGS into SYNC_MODE + SYNC_BRANCH_ARG (branch form) / SYNC_ISSUE_ARGS (issue form).
# Done after the parse loop so all args are collected before classification.
#
# Rules:
#   zero args                → all-repo form (SYNC_MODE=all)
#   one or more all-digit args → issue form (SYNC_MODE=issue)
#   exactly one non-digit arg → branch form (SYNC_MODE=branch), sets SYNC_BRANCH_ARG
#   multiple non-digit args or mixed → usage error (rejected at dispatch time; SYNC_MODE=invalid)
SYNC_ISSUE_ARGS=()
if [ "$MODE" = "sync" ]; then
  _sync_argc=${#SYNC_ARGS[@]}
  if [ "$_sync_argc" -eq 0 ]; then
    SYNC_MODE="all"
  else
    _sync_all_numeric=true
    _sync_non_numeric_count=0
    for _sync_a in "${SYNC_ARGS[@]+"${SYNC_ARGS[@]}"}"; do
      if [[ "$_sync_a" =~ ^[0-9]+$ ]]; then
        SYNC_ISSUE_ARGS+=("$_sync_a")
      else
        _sync_all_numeric=false
        _sync_non_numeric_count=$(( _sync_non_numeric_count + 1 ))
        SYNC_BRANCH_ARG="$_sync_a"
      fi
    done
    if [ "$_sync_all_numeric" = "true" ]; then
      # All digits: issue form
      SYNC_MODE="issue"
    elif [ "$_sync_non_numeric_count" -eq 1 ] && [ "${#SYNC_ISSUE_ARGS[@]}" -eq 0 ]; then
      # Exactly one non-numeric, no numerics: branch form
      SYNC_MODE="branch"
    else
      # Mixed or multiple non-numeric: usage error
      SYNC_MODE="invalid"
    fi
  fi
fi
# --- end sync arg-type resolution -------------------------------------------

# --- resolve_dispatch_key (pure) ---------------------------------------------
# Maps the dispatch tuple (MODE, batch filter, PR input, issue args) to a
# machine-readable routing key consumed by BOTH the dry-run printer and the
# real dispatch chain.  This is the single source of truth for routing
# decisions — neither the dry-run printer nor the real dispatch section may
# contain independent routing conditionals that could drift from each other.
#
# Usage:  resolve_dispatch_key MODE BATCH_FILTER PR_INPUT [ISSUE_ARGS...]
# Output: one token on stdout:
#   "status-repo-wide"     rite --status (no issue)
#   "batch-filter"         rite --label ...
#   "pr-resolve"           rite --pr N
#   "no-target"            no issue number, --label, or --pr supplied
#   "single-issue"         rite N (full mode)
#   "single-issue-text"    rite "description text" (full mode)
#   "batch-multi"          rite N1 N2 ... (full mode, >1 arg)
#   "dev-and-pr"           rite N --dev-and-pr
#   "status-per-issue"     rite N --status
#   "review-latest"        rite N --review-latest
#   "assess-and-fix"       rite N --assess-and-fix
#   "undo"                 rite N --undo
#   "health-report"        rite --health-report
#   "health-report-latest" rite --health-report --latest
#   "full-suite"           rite --full-suite
#   "sync"                 rite --sync <branch>   (branch form: merge origin/main into integration branch)
#   "sync-issue"           rite --sync N [M...]   (issue form: rebase feature branches onto resolver base)
#   "sync-all"             rite --sync            (all-repo: sweep ledger branches then in-flight worktrees)
#   "sync-invalid"         mixed/multi-branch args — usage error
#   "refresh-encountered-issues"
#   "tags"
#   "backfill-locks"
#   "reset-approval-issue" rite N --reset-approval
#   "reset-approval-all"   rite --reset-approval
#   "init"
#   "plan"
#   "mixed-pr-and-issues"  ambiguous: --pr N plus positional issue numbers
#   ""                     (empty) = unrecognized tuple; caller must refuse
# Return: always 0 (callers check the output string)
resolve_dispatch_key() {
  local _mode="$1" _batch_filter="$2" _pr_input="$3"
  shift 3
  local _argc=$#

  # Early-dispatch modes (take precedence over batch filter / PR / issue args).
  case "$_mode" in
    health-report)
      if [ "${1:-}" = "--latest" ]; then
        echo "health-report-latest"
      else
        echo "health-report"
      fi
      return 0
      ;;
    full-suite)
      echo "full-suite"
      return 0
      ;;
    sync)
      # Typed dispatch: key depends on SYNC_MODE resolved from SYNC_ARGS at parse time.
      case "${SYNC_MODE:-}" in
        all)     echo "sync-all" ;;
        issue)   echo "sync-issue" ;;
        branch)  echo "sync" ;;
        invalid) echo "sync-invalid" ;;
        *)       echo "sync-all" ;;  # default: no args = all-repo
      esac
      return 0
      ;;
    refresh-encountered-issues)
      echo "refresh-encountered-issues"
      return 0
      ;;
    tags)
      echo "tags"
      return 0
      ;;
    backfill-locks)
      echo "backfill-locks"
      return 0
      ;;
    reset-approval)
      if [ $_argc -ge 1 ]; then
        echo "reset-approval-issue"
      else
        echo "reset-approval-all"
      fi
      return 0
      ;;
    init)
      echo "init"
      return 0
      ;;
    plan)
      echo "plan"
      return 0
      ;;
    full|dev-and-pr|review-latest|assess-and-fix|status|undo)
      # Smart-routing modes — tuple-based routing below.
      ;;
    *)
      echo ""
      return 0
      ;;
  esac

  # Refuse ambiguous mixed tuple: --pr N plus positional issue numbers.
  if [ -n "$_pr_input" ] && [ $_argc -gt 0 ]; then
    echo "mixed-pr-and-issues"
    return 0
  fi

  # Smart-routing precedence: status-no-args → batch filter → --pr → argc.
  if [ "$_mode" = "status" ] && [ $_argc -eq 0 ] && [ -z "$_pr_input" ]; then
    echo "status-repo-wide"
    return 0
  fi

  if [ -n "$_batch_filter" ]; then
    echo "batch-filter"
    return 0
  fi

  if [ -n "$_pr_input" ]; then
    echo "pr-resolve"
    return 0
  fi

  if [ $_argc -eq 0 ]; then
    echo "no-target"
    return 0
  fi

  case "$_mode" in
    full)
      if [ $_argc -gt 1 ]; then
        echo "batch-multi"
      elif [[ "${1:-}" =~ ^[0-9]+$ ]]; then
        echo "single-issue"
      else
        echo "single-issue-text"
      fi
      return 0
      ;;
    dev-and-pr)
      if [ $_argc -eq 1 ]; then echo "dev-and-pr"; else echo ""; fi
      return 0
      ;;
    review-latest)
      if [ $_argc -eq 1 ]; then echo "review-latest"; else echo ""; fi
      return 0
      ;;
    assess-and-fix)
      if [ $_argc -eq 1 ]; then echo "assess-and-fix"; else echo ""; fi
      return 0
      ;;
    status)
      if [ $_argc -eq 1 ]; then echo "status-per-issue"; else echo ""; fi
      return 0
      ;;
    undo)
      if [ $_argc -eq 1 ]; then echo "undo"; else echo "undo-bad-args"; fi
      return 0
      ;;
  esac

  echo ""
  return 0
}
# --- end resolve_dispatch_key -------------------------------------------------

# --- resolve_dispatch_plan (pure) --------------------------------------------
# Maps the dispatch tuple to human-readable plan lines for --dry-run display.
# Delegates all routing decisions to resolve_dispatch_key() so the plan can
# never drift from the real dispatch chain.
#
# Usage:  resolve_dispatch_plan MODE BATCH_FILTER PR_INPUT [ISSUE_ARGS...]
# Output: plan lines on stdout. No side effects, no network, no filesystem
#         writes. Display detail comes from parser globals (TAGS_SUBARG,
#         PLAN_ARGS, LABEL_FILTER, SUPERVISED, WORKFLOW_FLAGS) when present,
#         with safe defaults so the function is callable standalone.
# Return: 0 = recognized tuple (plan printed)
#         2 = no target specified
#         1 = unrecognized tuple (caller must refuse)
resolve_dispatch_plan() {
  local _mode="$1" _batch_filter="$2" _pr_input="$3"
  shift 3

  local _key
  _key=$(resolve_dispatch_key "$_mode" "$_batch_filter" "$_pr_input" "$@")

  case "$_key" in
    health-report-latest)
      echo "rite-health-report --latest  (display most recent report, read-only)"
      return 0
      ;;
    health-report)
      echo "rite-health-report --display  (generate health report via claude)"
      return 0
      ;;
    full-suite)
      echo "rite-full-suite  (unfiltered make check + bats -r tests/)"
      return 0
      ;;
    sync)
      echo "integration-sync.sh::sync_integration_branch ${SYNC_BRANCH_ARG:-<branch>}  (fetch + merge origin/main into branch, push)"
      return 0
      ;;
    sync-issue)
      echo "integration-sync.sh::sync_issue_branch ${SYNC_ISSUE_ARGS[*]+"${SYNC_ISSUE_ARGS[*]}"}  (rebase each feature branch onto resolver-determined base, --force-with-lease)"
      echo "NOTE: rebasing rewrites SHAs — existing review goes stale and will be regenerated on next 'rite N'"
      return 0
      ;;
    sync-all)
      echo "integration-sync.sh::sync_all_repos  (Phase A: sync all ledger integration branches; Phase B: rebase all in-flight worktrees via issue paths)"
      echo "NOTE: rebasing rewrites SHAs — stale reviews will be regenerated on next 'rite N'"
      return 0
      ;;
    sync-invalid)
      echo "ERROR: mixed or multiple non-numeric args to --sync — provide: a branch name, issue number(s), or no args"
      echo "Usage: rite --sync <integration-branch>   # merge origin/main into branch"
      echo "       rite --sync N [M ...]              # rebase feature branch(es) for issue(s)"
      echo "       rite --sync                        # sweep all ledger branches + in-flight worktrees"
      return 1
      ;;
    refresh-encountered-issues)
      echo "render_encountered_issues  (fetch closed recurring-pattern issues via gh, rewrite docs/architecture/encountered-issues.md)"
      return 0
      ;;
    tags)
      echo "show_tag_index ${TAGS_SUBARG:-}  (read-only tag index display)"
      return 0
      ;;
    backfill-locks)
      echo "backfill_worktree_locks  (write lock dirs for legacy worktrees)"
      return 0
      ;;
    reset-approval-issue)
      echo "clear saved blocker approvals for issue #${1}"
      return 0
      ;;
    reset-approval-all)
      echo "clear ALL saved blocker approvals (global reset)"
      return 0
      ;;
    init)
      echo "initialize .rite/ in ${RITE_PROJECT_ROOT:-<project-root>}  (create config/templates, GitHub setup)"
      return 0
      ;;
    plan)
      echo "plan-issues.sh::plan_issues ${PLAN_ARGS[*]:-}  (generate GitHub issues via claude)"
      return 0
      ;;
    status-repo-wide)
      echo "repo_wide_status ${LABEL_FILTER:-}  (read-only repo overview)"
      return 0
      ;;
    batch-filter)
      if [ $# -gt 0 ]; then
        echo "batch-process-issues.sh $_batch_filter $* --auto  (batch via filter)"
      else
        echo "batch-process-issues.sh $_batch_filter --auto  (batch via filter)"
      fi
      return 0
      ;;
    pr-resolve)
      echo "resolve PR #$_pr_input to its linked issue via gh  (orphan PR: creates a tracking issue, may close the PR if stale)"
      echo "then dispatch the resolved issue through mode=$_mode"
      return 0
      ;;
    no-target)
      return 2
      ;;
    single-issue)
      if [ "${SUPERVISED:-false}" = true ]; then
        echo "workflow-runner.sh $1 ${WORKFLOW_FLAGS[*]:-}  (full lifecycle, supervised)"
      else
        echo "workflow-runner.sh $1 --auto ${WORKFLOW_FLAGS[*]:-}  (full lifecycle)"
      fi
      return 0
      ;;
    single-issue-text)
      echo "generate structured issue from text description via claude,"
      echo "then workflow-runner.sh <new-issue>  (full lifecycle)"
      return 0
      ;;
    batch-multi)
      echo "batch-process-issues.sh $* --auto  (batch: $# issues)"
      return 0
      ;;
    dev-and-pr)
      echo "claude-workflow.sh $1 --auto, then create-pr.sh --auto  (dev + PR only, skip review/merge)"
      return 0
      ;;
    review-latest)
      echo "local-review.sh <pr-for-issue-$1> --post  (generate + post review)"
      return 0
      ;;
    assess-and-fix)
      echo "assess-and-resolve.sh <pr-for-issue-$1> $1 --auto  (assess review + fix loop)"
      return 0
      ;;
    status-per-issue)
      echo "per-issue status overview for issue #$1  (read-only)"
      return 0
      ;;
    undo)
      echo "undo-workflow.sh $1  (close PR, delete branch/worktree)"
      return 0
      ;;
    undo-bad-args)
      echo "ERROR: --undo requires exactly one issue number (got $# args)"
      return 1
      ;;
    mixed-pr-and-issues)
      # Surface the ambiguity to the dry-run printer; real dispatch refuses loudly.
      echo "ERROR: ambiguous invocation — --pr $_pr_input and positional issue(s) $* cannot be combined"
      return 1
      ;;
    "")
      return 1
      ;;
    *)
      return 1
      ;;
  esac
}
# --- end resolve_dispatch_plan ------------------------------------------------

# Dry-run choke point (fail-closed): plan-and-exit BEFORE any side effect.
# MUST stay immediately after the arg-parse loop and BEFORE the logging block
# below — logging setup creates a log file and rotates (deletes) old logs, and
# six modes (health-report, full-suite, refresh-encountered-issues, tags,
# backfill-locks, reset-approval) dispatch before the smart-routing section.
# RITE_DRY_RUN=true may arrive via the --dry-run flag, the environment, or
# .rite/config — all three plan-and-exit here.
#
# Known residual: config.sh's ensure_timeout_cmd (sourced above) can
# auto-install coreutils before this point. The guarantee is "no
# git/gh/claude/log/workflow side effects after arg parsing", not literally zero.
if [ "${RITE_DRY_RUN:-false}" = "true" ]; then
  echo ""
  print_header "Dry Run — Execution Plan"
  echo "  Project:    ${RITE_PROJECT_NAME:-unknown} (${RITE_PROJECT_ROOT:-unknown})"
  echo "  Invocation: mode=$MODE args=[${ARGS[*]:-}] filter=[${BATCH_FILTER_ARGS[*]:-}] pr=[${PR_INPUT:-}]"
  set +e
  _DRY_RUN_PLAN=$(resolve_dispatch_plan "$MODE" "${BATCH_FILTER_ARGS[*]:-}" "${PR_INPUT:-}" ${ARGS[@]+"${ARGS[@]}"})
  _DRY_RUN_RC=$?
  set -e
  if [ $_DRY_RUN_RC -eq 0 ]; then
    echo "  Would execute:"
    echo "$_DRY_RUN_PLAN" | sed 's/^/    /'
    echo ""
    print_info "Dry run complete — nothing was executed"
    exit 0
  elif [ $_DRY_RUN_RC -eq 2 ]; then
    print_error "dry-run: no target specified (an issue number, --label, or --pr is required)"
    exit 1
  else
    # Surface the plan text (e.g. "ERROR: ambiguous invocation — ...") so the
    # dry-run output matches the real execution's refusal wording.  A bare
    # generic message would hide the actual reason (mixed --pr + issue args,
    # unrecognized mode, etc.) and break the parity contract.
    if [ -n "${_DRY_RUN_PLAN:-}" ]; then
      print_error "$_DRY_RUN_PLAN"
    else
      print_error "dry-run: unsupported invocation — refusing (mode=$MODE args=[${ARGS[*]:-}] filter=[${BATCH_FILTER_ARGS[*]:-}] pr=[${PR_INPUT:-}])"
    fi
    exit 1
  fi
fi

# Set up logging (on by default, --no-log to disable)
# Read-only commands skip logging
if [ "$MODE" = "status" ] || [ "$MODE" = "health-report" ] || [ "$MODE" = "init" ] || [ "$MODE" = "reset-approval" ] || [ "$MODE" = "backfill-locks" ] || [ "$MODE" = "refresh-encountered-issues" ] || [ "$MODE" = "tags" ] || [ "$MODE" = "full-suite" ]; then
  # full-suite manages its own log file (per-run to .rite/logs/full-suite-YYYYMMDD.log)
  RITE_LOG_AUTO=false
fi

# Health report: dispatch immediately (no issue number needed)
if [ "$MODE" = "health-report" ]; then
  if [ "${ARGS[0]:-}" = "--latest" ]; then
    exec "$SCRIPT_DIR/rite-health-report" --latest
  fi
  exec "$SCRIPT_DIR/rite-health-report" --display
fi

# Full-suite safety net: run unfiltered make check + bats -r tests/
# Bypasses targeted-selection logic; manages its own per-run log file.
if [ "$MODE" = "full-suite" ]; then
  exec "$SCRIPT_DIR/rite-full-suite"
fi

# Integration sync: typed dispatch based on SYNC_MODE resolved at parse time.
# Explicit, never automatic. Never entered by the workflow or batch paths.
if [ "$MODE" = "sync" ]; then
  source "$RITE_LIB_DIR/utils/integration-sync.sh"
  case "${SYNC_MODE:-all}" in
    branch)
      # Branch form: merge origin/main into the named integration branch.
      # Refuses "main" (handled inside sync_integration_branch).
      sync_integration_branch "${SYNC_BRANCH_ARG:-}"
      exit $?
      ;;
    issue)
      # Issue form: rebase each in-flight feature branch onto its resolver-determined base.
      _sync_issue_rc=0
      for _sync_n in "${SYNC_ISSUE_ARGS[@]+"${SYNC_ISSUE_ARGS[@]}"}"; do
        sync_issue_branch "$_sync_n" || _sync_issue_rc=$?
      done
      exit $_sync_issue_rc
      ;;
    all)
      # All-repo form: Phase A (ledger integration branches) then Phase B (in-flight worktrees).
      sync_all_repos
      exit $?
      ;;
    invalid)
      print_error "--sync: mixed or multiple non-numeric args — cannot determine sync type"
      echo "Usage: rite --sync <integration-branch>   # merge origin/main into branch" >&2
      echo "       rite --sync N [M ...]              # rebase feature branch(es) for issue(s)" >&2
      echo "       rite --sync                        # sweep all ledger branches + in-flight worktrees" >&2
      exit 1
      ;;
  esac
fi

# Refresh encountered-issues catalog: invoke the renderer (no issue number needed)
if [ "$MODE" = "refresh-encountered-issues" ]; then
  source "$RITE_LIB_DIR/utils/encountered-issues-renderer.sh"
  render_encountered_issues
  exit 0
fi

# Tag index: read-only display of the tag-index system state
if [ "$MODE" = "tags" ]; then
  source "$RITE_LIB_DIR/utils/tag-index.sh"
  show_tag_index "${TAGS_SUBARG:-}"
  exit 0
fi

# Backfill locks: walk worktrees, write lock files for legacy worktrees
if [ "$MODE" = "backfill-locks" ]; then
  source "$RITE_LIB_DIR/utils/issue-lock.sh"
  print_info "Backfilling lock files for legacy worktrees..."
  backfill_worktree_locks
  print_success "Backfill complete — run 'rite --status' to verify issue associations"
  exit 0
fi

# Reset approval state: dispatch immediately (no workflow setup needed)
if [ "$MODE" = "reset-approval" ]; then
  source "$RITE_LIB_DIR/utils/session-tracker.sh"

  ISSUE_ARG="${ARGS[0]:-}"

  if [ -n "$ISSUE_ARG" ]; then
    # Issue-scoped reset: clear all approvals for the given issue number
    if [[ ! "$ISSUE_ARG" =~ ^[0-9]+$ ]]; then
      print_error "--reset-approval: issue number must be numeric (got: $ISSUE_ARG)"
      exit 1
    fi

    APPROVAL_FILE="$(_get_approval_state_file)"
    if [ ! -f "$APPROVAL_FILE" ]; then
      print_info "No approval state file found — nothing to reset for issue #$ISSUE_ARG"
      exit 0
    fi

    # Show what will be removed before clearing
    ENTRIES=$(jq -r --arg prefix "${ISSUE_ARG}:" \
      '.approved_blockers // [] | map(select(startswith($prefix))) | join(", ")' \
      "$APPROVAL_FILE" 2>/dev/null || true)
    ENTRIES="${ENTRIES:-}"

    if [ -z "$ENTRIES" ]; then
      print_info "No saved approvals for issue #$ISSUE_ARG"
      exit 0
    fi

    if [ "$SUPERVISED" = true ]; then
      echo ""
      echo "Approvals to remove for issue #$ISSUE_ARG: $ENTRIES"
      echo ""
      read -p "Clear these approvals? (y/n) " -n 1 -r
      echo
      if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        print_info "Reset cancelled"
        exit 0
      fi
    fi

    reset_approved_blockers_for_issue "$ISSUE_ARG"
    print_success "Cleared blocker approvals for issue #$ISSUE_ARG ($ENTRIES)"
  else
    # Global reset: clear ALL approvals across all issues
    APPROVAL_FILE="$(_get_approval_state_file)"
    if [ ! -f "$APPROVAL_FILE" ]; then
      print_info "No approval state file found — nothing to reset"
      exit 0
    fi

    TOTAL=$(jq '.approved_blockers // [] | length' "$APPROVAL_FILE" 2>/dev/null || echo "0")
    TOTAL="${TOTAL:-0}"

    if [ "$TOTAL" -eq 0 ]; then
      print_info "No saved approvals found — nothing to reset"
      exit 0
    fi

    if [ "$SUPERVISED" = true ]; then
      echo ""
      echo "This will clear ALL $TOTAL saved blocker approvals across all issues."
      echo ""
      read -p "Clear all approvals? (y/n) " -n 1 -r
      echo
      if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        print_info "Reset cancelled"
        exit 0
      fi
    fi

    reset_all_approved_blockers
    print_success "Cleared all saved blocker approvals ($TOTAL entries removed)"
  fi
  exit 0
fi

if [ "$RITE_LOG_AUTO" = true ] && [ -z "$RITE_LOG_FILE" ]; then
  LOG_TIMESTAMP=$(date '+%Y%m%d-%H%M%S')

  # Log filename keyed by issue number(s). Multiple issues are joined with
  # dashes (e.g., rite-25-26-20260317-103034.log). Description strings use
  # "new" — the issue gets created later.
  if [ "$MODE" = "plan" ]; then
    LOG_SLUG="plan"
  elif [ ${#BATCH_FILTER_ARGS[@]} -gt 0 ]; then
    # Batch mode: e.g., "batch-label-tech-debt"
    LOG_SLUG="batch-${BATCH_FILTER_ARGS[*]}"
    LOG_SLUG="${LOG_SLUG//--/}"   # strip -- prefixes
    LOG_SLUG="${LOG_SLUG// /-}"   # spaces → dashes
  else
    LOG_SLUG=""
    for _arg in "${ARGS[@]+"${ARGS[@]}"}"; do
      if [[ "$_arg" =~ ^[0-9]+$ ]]; then
        LOG_SLUG="${LOG_SLUG:+${LOG_SLUG}-}${_arg}"
      fi
    done
    LOG_SLUG="${LOG_SLUG:-new}"
  fi
  RITE_LOG_FILE="$RITE_PROJECT_ROOT/$RITE_DATA_DIR/logs/rite-${LOG_SLUG}-${LOG_TIMESTAMP}.log"

  # Auto-prune: keep last 20 logs, delete older ones
  RITE_LOG_DIR="$RITE_PROJECT_ROOT/$RITE_DATA_DIR/logs"
  if [ -d "$RITE_LOG_DIR" ]; then
    LOG_COUNT=$(ls -1 "$RITE_LOG_DIR"/rite-*.log 2>/dev/null | wc -l | tr -d ' ') || true
    if [ "$LOG_COUNT" -gt 20 ]; then
      ls -1t "$RITE_LOG_DIR"/rite-*.log 2>/dev/null | tail -n +21 | xargs rm -f 2>/dev/null || true
    fi
  fi
fi

if [ -n "$RITE_LOG_FILE" ]; then
  mkdir -p "$(dirname "$RITE_LOG_FILE")"

  # Write log header
  {
    echo "=== Sharkrite Log ==="
    echo "Date: $(date '+%Y-%m-%d %H:%M:%S')"
    echo "Command: rite ${BATCH_FILTER_ARGS[*]:-} ${ARGS[*]:-} (mode=$MODE)"
    echo "Project: ${RITE_PROJECT_NAME:-unknown}"
    echo "Version: $VERSION"
    echo "==="
    echo ""
  } > "$RITE_LOG_FILE"

  # Single tee for both stdout and stderr to avoid log interleaving.
  # Two separate tee processes (one per fd) race when appending to the same file,
  # causing non-deterministic output ordering. Merging stderr into the tee'd stdout
  # ensures all output flows through one pipe and arrives in execution order.
  exec > >(tee >(strip_ansi >> "$RITE_LOG_FILE"))
  exec 2>&1

  export RITE_LOG_FILE
  print_info "Logging to: $RITE_LOG_FILE"
fi

# Handle init mode
if [ "$MODE" = "init" ]; then
  print_header "Initializing Sharkrite for $RITE_PROJECT_NAME"

  # Create .rite/ directory structure
  mkdir -p "$RITE_PROJECT_ROOT/$RITE_DATA_DIR"

  # Copy templates
  if [ ! -f "$RITE_PROJECT_ROOT/$RITE_DATA_DIR/config" ]; then
    cp "$RITE_INSTALL_DIR/config/project.conf.example" "$RITE_PROJECT_ROOT/$RITE_DATA_DIR/config"
    print_success "Created .rite/config"
  else
    print_info ".rite/config already exists, skipping"
  fi

  if [ ! -f "$RITE_PROJECT_ROOT/$RITE_DATA_DIR/blockers.conf" ]; then
    cp "$RITE_INSTALL_DIR/config/blockers.conf.example" "$RITE_PROJECT_ROOT/$RITE_DATA_DIR/blockers.conf"
    print_success "Created .rite/blockers.conf"
  else
    print_info ".rite/blockers.conf already exists, skipping"
  fi

  if [ ! -f "$RITE_PROJECT_ROOT/$RITE_DATA_DIR/scratch.md" ]; then
    cp "$RITE_INSTALL_DIR/templates/scratchpad.md" "$RITE_PROJECT_ROOT/$RITE_DATA_DIR/scratch.md"
    print_success "Created .rite/scratch.md"
  else
    print_info ".rite/scratch.md already exists, skipping"
  fi

  if [ ! -f "$RITE_PROJECT_ROOT/$RITE_DATA_DIR/.gitignore" ]; then
    cp "$RITE_INSTALL_DIR/templates/gitignore" "$RITE_PROJECT_ROOT/$RITE_DATA_DIR/.gitignore"
    print_success "Created .rite/.gitignore"
  else
    print_info ".rite/.gitignore already exists, skipping"
  fi

  if [ ! -f "$RITE_PROJECT_ROOT/$RITE_DATA_DIR/issue-template.md" ]; then
    cp "$RITE_INSTALL_DIR/templates/issue-template.md" "$RITE_PROJECT_ROOT/$RITE_DATA_DIR/issue-template.md"
    print_success "Created .rite/issue-template.md"
  else
    print_info ".rite/issue-template.md already exists, skipping"
  fi

  # doc-sync.md.example — inactive starter for Layer 2 doc maintenance
  # Users opt in by copying this to .rite/doc-sync.md (see README)
  if [ ! -f "$RITE_PROJECT_ROOT/$RITE_DATA_DIR/doc-sync.md.example" ]; then
    cp "$RITE_INSTALL_DIR/templates/doc-sync.md.example" "$RITE_PROJECT_ROOT/$RITE_DATA_DIR/doc-sync.md.example"
    print_success "Created .rite/doc-sync.md.example (inactive — copy to .rite/doc-sync.md to enable)"
  else
    print_info ".rite/doc-sync.md.example already exists, skipping"
  fi

  # ─────────────────────────────────────────────────────────────────
  # Doc-mode consent (Layer 2 activation)
  # ─────────────────────────────────────────────────────────────────
  _config_file_for_doc_mode="$RITE_PROJECT_ROOT/$RITE_DATA_DIR/config"
  _doc_sync_active="$RITE_PROJECT_ROOT/$RITE_DATA_DIR/doc-sync.md"
  _doc_sync_example="$RITE_PROJECT_ROOT/$RITE_DATA_DIR/doc-sync.md.example"

  # Source doc-consent helpers (provides record_doc_mode)
  source "$RITE_LIB_DIR/utils/doc-consent.sh"
  # Also ensure docs-map builder is available for both branches below
  source "$RITE_LIB_DIR/utils/docs-map.sh"

  # Determine consent state and act accordingly
  _doc_mode_already_recorded=false
  if grep -qE '^RITE_DOC_MODE=' "$_config_file_for_doc_mode" 2>/dev/null; then
    _doc_mode_already_recorded=true
  fi

  if [ "$_doc_mode_already_recorded" = "true" ]; then
    # Already recorded — load and announce
    _recorded_mode=$(grep -oE '^RITE_DOC_MODE="[^"]*"' "$_config_file_for_doc_mode" 2>/dev/null | cut -d'"' -f2 || true)
    print_info "Doc mode already configured: ${_recorded_mode:-sync}"
  elif [ -f "$_doc_sync_active" ]; then
    # .rite/doc-sync.md already exists (manual opt-in) — manual opt-in IS consent
    record_doc_mode "sync"
    print_success "Doc mode: sync (detected existing .rite/doc-sync.md — manual opt-in recorded)"
    # Build docs map (sync branch)
    docs_map_build
  else
    # Ask the consent question
    echo ""
    read -p "  May sharkrite update files in docs/ when code changes make them inaccurate? [Y/n] " -n 1 -r
    echo
    if [[ ! ${REPLY:-Y} =~ ^[Nn]$ ]]; then
      # Yes: scaffold .rite/doc-sync.md from template + record sync
      cp "$_doc_sync_example" "$_doc_sync_active"
      print_success "Created .rite/doc-sync.md (Layer 2 doc sync enabled)"
      record_doc_mode "sync"
      print_success "Doc mode: sync (docs/ will be kept accurate after merges)"
    else
      # No: record changelog only
      record_doc_mode "changelog"
      print_info "Doc mode: changelog (drift notes only; re-run rite --init to change)"
    fi
    # Build docs map (both branches)
    docs_map_build
  fi

  # Create backward-compat symlink if .claude/ exists
  if [ -d "$RITE_PROJECT_ROOT/.claude" ] && [ ! -e "$RITE_PROJECT_ROOT/.claude/scratch.md" ]; then
    ln -sf "../$RITE_DATA_DIR/scratch.md" "$RITE_PROJECT_ROOT/.claude/scratch.md"
    print_success "Created .claude/scratch.md symlink for backward compatibility"
  fi

  print_success "Sharkrite initialized for $RITE_PROJECT_NAME"

  # ─────────────────────────────────────────────────────────────────
  # Document Discovery (Claude-classified)
  # ─────────────────────────────────────────────────────────────────

  # Skip if RITE_PLAN_DOCS is already configured (uncommented in config)
  _config_file="$RITE_PROJECT_ROOT/$RITE_DATA_DIR/config"
  _plan_docs_configured=false
  if [ -f "$_config_file" ] && grep -q '^RITE_PLAN_DOCS=' "$_config_file" 2>/dev/null; then
    _plan_docs_configured=true
  fi

  if [ "$_plan_docs_configured" = false ]; then
    echo ""
    print_status "Scanning for documentation..."

    # Scan for candidate doc files
    _doc_candidates=()
    _skip_pattern="node_modules|\.git/|vendor/|\.rite/|CHANGELOG|LICENSE|CODE_OF_CONDUCT|CONTRIBUTING"

    # Root-level architectural docs
    for f in ARCHITECTURE.md DESIGN.md ROADMAP.md ADR*.md; do
      [ -f "$RITE_PROJECT_ROOT/$f" ] && _doc_candidates+=("$f")
    done

    # Recursive scan of common doc directories (max depth 3, markdown only)
    for dir in docs doc adr ADR architecture design; do
      if [ -d "$RITE_PROJECT_ROOT/$dir" ]; then
        while IFS= read -r f; do
          _rel="${f#$RITE_PROJECT_ROOT/}"
          if ! echo "$_rel" | grep -qE "$_skip_pattern"; then
            _doc_candidates+=("$_rel")
          fi
        done < <(find "$RITE_PROJECT_ROOT/$dir" -maxdepth 3 -type f \( -name "*.md" -o -name "*.txt" -o -name "*.rst" \) 2>/dev/null | sort)
      fi
    done

    if [ ${#_doc_candidates[@]} -eq 0 ]; then
      print_info "No documentation files found. Configure RITE_PLAN_DOCS later in .rite/config"
    elif ! command -v claude &>/dev/null; then
      print_warning "Claude not available for doc classification"
      print_info "Found ${#_doc_candidates[@]} doc(s). Configure RITE_PLAN_DOCS manually in .rite/config"
    else
      # Build snippets for Claude classification
      _doc_snippets=""
      for _doc in "${_doc_candidates[@]}"; do
        _doc_snippets+="--- $_doc ---"$'\n'
        _doc_snippets+=$(head -30 "$RITE_PROJECT_ROOT/$_doc" 2>/dev/null || echo "(unreadable)")
        _doc_snippets+=$'\n\n'
      done

      # Classify via Claude
      _classify_prompt=$(cat << 'CLASSIFY_EOF'
Classify each document into exactly one category. Output ONLY a JSON array, no markdown fences, no explanation.

Categories:
- "planning" — Architecture, design, implementation phases, roadmaps, ADRs, technical specs intended to drive development work
- "reference" — API docs, changelogs, READMEs, contributing guides, usage docs
- "security" — Auth specs, compliance requirements, vulnerability policies, secrets management, access control
- "operational" — Deployment runbooks, monitoring setup, incident response, infrastructure docs

Output format: [{"path": "docs/foo.md", "category": "planning", "reason": "3-5 word description"}]

Documents to classify:

CLASSIFY_EOF
)
      _classify_prompt+="$_doc_snippets"

      source "$RITE_LIB_DIR/providers/provider-interface.sh"
      load_provider "${RITE_UTILITY_PROVIDER:-claude}"
      # Doc categorization is a cheap classification — use the explicit "triage" role
      # (haiku), never "" (which would fall through to the expensive review model).
      _classification=$(provider_run_prompt "$_classify_prompt" "$(provider_resolve_model triage)" true 2>/dev/null) || _classification=""

      if [ -z "$_classification" ]; then
        print_warning "Doc classification failed. Configure RITE_PLAN_DOCS manually in .rite/config"
      else
        # Strip markdown fences if Claude added them despite instructions
        _classification=$(echo "$_classification" | sed '/^```/d' || true)

        # Parse categories
        _planning_docs=()
        _planning_reasons=()
        _security_docs=()
        _security_reasons=()
        _reference_docs=()
        _operational_docs=()

        _doc_count=$(echo "$_classification" | jq -r 'length' 2>/dev/null || echo "0")
        for (( i=0; i<_doc_count; i++ )); do
          _path=$(echo "$_classification" | jq -r ".[$i].path" 2>/dev/null)
          _cat=$(echo "$_classification" | jq -r ".[$i].category" 2>/dev/null)
          _reason=$(echo "$_classification" | jq -r ".[$i].reason" 2>/dev/null)
          case "$_cat" in
            planning)    _planning_docs+=("$_path"); _planning_reasons+=("$_reason") ;;
            security)    _security_docs+=("$_path"); _security_reasons+=("$_reason") ;;
            reference)   _reference_docs+=("$_path") ;;
            operational) _operational_docs+=("$_path") ;;
          esac
        done

        # Display results
        echo ""
        print_header "Document Discovery"

        if [ ${#_planning_docs[@]} -gt 0 ]; then
          echo ""
          echo "  Planning docs (recommended for issue generation):"
          for (( i=0; i<${#_planning_docs[@]}; i++ )); do
            echo "    + ${_planning_docs[$i]} — ${_planning_reasons[$i]}"
          done
        fi

        if [ ${#_security_docs[@]} -gt 0 ]; then
          echo ""
          echo "  Security docs (review before adding):"
          for (( i=0; i<${#_security_docs[@]}; i++ )); do
            echo "    ! ${_security_docs[$i]} — ${_security_reasons[$i]}"
          done
        fi

        if [ ${#_reference_docs[@]} -gt 0 ]; then
          echo ""
          echo "  Reference docs (skipped):"
          for _doc in "${_reference_docs[@]}"; do
            echo "    · $_doc"
          done
        fi

        if [ ${#_operational_docs[@]} -gt 0 ]; then
          echo ""
          echo "  Operational docs (skipped):"
          for _doc in "${_operational_docs[@]}"; do
            echo "    · $_doc"
          done
        fi

        # Prompt for approval
        if [ ${#_planning_docs[@]} -gt 0 ]; then
          echo ""
          read -p "  Add planning docs to .rite/config? [Y/n] " -n 1 -r
          echo
          _selected_docs=()
          if [[ ! $REPLY =~ ^[Nn]$ ]]; then
            _selected_docs+=("${_planning_docs[@]}")
          fi

          if [ ${#_security_docs[@]} -gt 0 ]; then
            read -p "  Include security docs too? [y/N] " -n 1 -r
            echo
            if [[ $REPLY =~ ^[Yy]$ ]]; then
              _selected_docs+=("${_security_docs[@]}")
            fi
          fi

          if [ ${#_selected_docs[@]} -gt 0 ]; then
            _docs_value="${_selected_docs[*]}"
            # Update config: uncomment and populate RITE_PLAN_DOCS
            if grep -q '# RITE_PLAN_DOCS=' "$_config_file" 2>/dev/null; then
              portable_sed_i "s|# RITE_PLAN_DOCS=.*|RITE_PLAN_DOCS=\"$_docs_value\"|" "$_config_file"
            else
              echo "" >> "$_config_file"
              echo "RITE_PLAN_DOCS=\"$_docs_value\"" >> "$_config_file"
            fi
            print_success "Configured RITE_PLAN_DOCS with ${#_selected_docs[@]} doc(s)"
          fi
        else
          echo ""
          print_info "No planning docs found. Configure RITE_PLAN_DOCS later if needed."
        fi
      fi
    fi
  fi

  # ─────────────────────────────────────────────────────────────────
  # GitHub Setup (auto-created)
  # ─────────────────────────────────────────────────────────────────

  echo ""
  print_info "GitHub Setup"

  # Deprecation warning for old auto-review workflow
  if [ -f ".github/workflows/claude-code-review.yml" ]; then
    print_warning "Found deprecated claude-code-review.yml workflow"
    print_info "Sharkrite now uses local reviews — this GitHub Actions workflow can be removed"
  fi

  # Review instructions (used by local-review.sh) — always create
  if [ ! -f ".github/claude-code/pr-review-instructions.md" ]; then
    mkdir -p .github/claude-code
    cp "$RITE_INSTALL_DIR/templates/github/claude-code/pr-review-instructions.md" .github/claude-code/
    print_success "Created .github/claude-code/pr-review-instructions.md"
  else
    print_info ".github/claude-code/pr-review-instructions.md already exists, skipping"
  fi

  # PR template — always create (sharkrite creates PRs, every repo needs this)
  if [ ! -f ".github/PULL_REQUEST_TEMPLATE.md" ]; then
    mkdir -p .github
    cp "$RITE_INSTALL_DIR/templates/github/PULL_REQUEST_TEMPLATE.md" .github/
    print_success "Created .github/PULL_REQUEST_TEMPLATE.md"
  else
    print_info ".github/PULL_REQUEST_TEMPLATE.md already exists, skipping"
  fi

  # Optional: Slack merge notifications
  if [ ! -f ".github/workflows/pr-merged-notification.yml" ]; then
    echo ""
    read -p "Send Slack notifications on PR merge? (y/n) " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
      mkdir -p .github/workflows
      cp "$RITE_INSTALL_DIR/templates/github/workflows/pr-merged-notification.yml" .github/workflows/
      print_success "Created .github/workflows/pr-merged-notification.yml"
      print_info "Add SLACK_WEBHOOK secret to enable notifications"
    fi
  fi

  # ─────────────────────────────────────────────────────────────────
  # Notifications Setup
  # ─────────────────────────────────────────────────────────────────

  _config_file="${_config_file:-$RITE_PROJECT_ROOT/$RITE_DATA_DIR/config}"
  _notifications_configured=false
  if [ -f "$_config_file" ] && grep -q '^RITE_NOTIFICATIONS=' "$_config_file" 2>/dev/null; then
    _notifications_configured=true
  fi

  if [ "$_notifications_configured" = false ]; then
    echo ""
    read -p "Enable Slack notifications for this project? [y/N] " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
      # Ask for webhook URL (check env as default)
      _default_webhook="${SLACK_WEBHOOK:-}"
      if [ -n "$_default_webhook" ]; then
        echo "  Found SLACK_WEBHOOK in environment."
        read -p "  Use it? [Y/n] " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Nn]$ ]]; then
          _default_webhook=""
        fi
      fi

      if [ -z "$_default_webhook" ]; then
        read -p "  Slack webhook URL: " _default_webhook
        echo
      fi

      # Write to config
      if [ -n "$_default_webhook" ]; then
        {
          echo ""
          echo "# Notifications"
          echo "RITE_NOTIFICATIONS=\"true\""
          echo "SLACK_WEBHOOK=\"$_default_webhook\""
        } >> "$_config_file"
        print_success "Notifications enabled with Slack"
      else
        print_info "No webhook provided, skipping notifications"
      fi
    else
      # Explicitly set to false so we don't ask again
      {
        echo ""
        echo "# Notifications (disabled — re-run --init or edit to enable)"
        echo "RITE_NOTIFICATIONS=\"false\""
      } >> "$_config_file"
      print_info "Notifications disabled for this project"
    fi
  fi

  echo ""
  print_info "Next steps:"
  echo "  1. Edit .rite/config with project-specific settings"
  echo "  2. Edit .rite/blockers.conf to customize blocker path patterns"
  echo "  3. Run 'rite 21' to process your first issue"
  echo ""
  exit 0
fi

# Handle plan mode (before normalize — plan doesn't need issue normalization)
if [ "$MODE" = "plan" ]; then
  source "$RITE_LIB_DIR/core/plan-issues.sh"
  plan_issues "${PLAN_ARGS[@]+"${PLAN_ARGS[@]}"}"
  exit $?
fi

# Source normalization utilities
source "$RITE_LIB_DIR/utils/normalize-issue.sh"

# Source shared PR-number refusal helper (single source of truth for exit-15 guard)
source "$RITE_LIB_DIR/utils/pr-refusal.sh"

# ---------------------------------------------------------------------------
# _reject_if_pr_number ISSUE_NUMBER
#
# Guard for phase commands (--status, --review-latest, --assess-and-fix) that
# accept a bare number but do not route through run_workflow()'s /pull/ check.
# GitHub's shared number space means `gh issue view <PR#>` succeeds and returns
# the PR — the url field discriminates (/pull/ vs /issues/).
#
# If the number refers to a PR, prints a named-PR error (matching the
# handle_pr_number_refused() output style from workflow-runner.sh) and exits 15.
# Exit 15 is the canonical sentinel for "bare PR number passed as issue".
# See: docs/architecture/exit-codes.md — exit code 15
# See: handle_pr_number_refused() in lib/core/workflow-runner.sh
# ---------------------------------------------------------------------------
_reject_if_pr_number() {
  local _n="$1"
  # Delegate to the shared helper (lib/utils/pr-refusal.sh).
  # The helper fetches issue data, prints the canonical refusal message,
  # and returns 15 when the number resolves to a PR.
  # bin/rite uses exit (not return) because it is a top-level entrypoint.
  refuse_if_pr_number "$_n" "" "rite" || exit 15
}

# Normalize and resolve issue input.
# Runs in the MAIN shell (not a subshell) so NORMALIZED_SUBJECT, WORK_DESCRIPTION,
# ISSUE_NUMBER, and ISSUE_DESC are available to the calling scope.
#
# For numeric input: fetches issue details from GitHub, applies bash cleanup to title.
# For text input: uses Claude to generate a structured issue, prompts for approval.
normalize_and_resolve() {
  local input="$1"

  if [[ "$input" =~ ^[0-9]+$ ]]; then
    # Pre-existing issue — fetch details, then normalize title
    ISSUE_NUMBER="$input"

    ISSUE_JSON=$(gh_safe issue view "$ISSUE_NUMBER" --json title,body,state || true)
    ISSUE_JSON="${ISSUE_JSON:-}"
    if [ -z "$ISSUE_JSON" ] || [ "$ISSUE_JSON" = "null" ]; then
      print_error "Issue #$ISSUE_NUMBER not found on GitHub"
      exit 1
    fi

    ISSUE_DESC=$(echo "$ISSUE_JSON" | jq -r '.title')
    ISSUE_BODY=$(echo "$ISSUE_JSON" | jq -r '.body // ""')
    local issue_state
    issue_state=$(echo "$ISSUE_JSON" | jq -r '.state')

    if [ -z "$ISSUE_DESC" ] || [ "$ISSUE_DESC" = "null" ]; then
      print_error "Issue #$ISSUE_NUMBER has no title"
      exit 1
    fi

    if [ "$issue_state" = "CLOSED" ]; then
      print_warning "Issue #$ISSUE_NUMBER is already CLOSED — proceeding anyway"
    fi

    normalize_existing_issue  # Sets NORMALIZED_SUBJECT, WORK_DESCRIPTION
  else
    # Text description — generate structured issue via Claude, prompt for approval
    if ! normalize_piped_input "$input"; then
      exit 1
    fi
    # normalize_piped_input sets: ISSUE_NUMBER, ISSUE_DESC, NORMALIZED_SUBJECT,
    # WORK_DESCRIPTION, GENERATED_ISSUE_BODY
    ISSUE_BODY="${GENERATED_ISSUE_BODY:-}"
  fi

  export ISSUE_NUMBER ISSUE_DESC NORMALIZED_SUBJECT WORK_DESCRIPTION ISSUE_BODY
}

# Pre-flight: check Claude CLI is available (not needed for --undo)
if [ "$MODE" != "undo" ]; then
  if ! command -v claude &>/dev/null && ! command -v claude-code &>/dev/null; then
    print_error "Claude CLI not found"
    echo ""
    echo "Sharkrite requires Claude Code to run workflows."
    echo "Install it with: npm install -g @anthropic-ai/claude-code"
    echo "Then authenticate: claude"
    echo ""
    exit 1
  fi
fi

# Pre-flight: check gh CLI and auth
if ! command -v gh &>/dev/null; then
  print_error "GitHub CLI (gh) not found"
  echo ""
  echo "Sharkrite requires the GitHub CLI."
  echo "Install it with: brew install gh"
  echo "Then authenticate: gh auth login"
  echo ""
  exit 1
fi

if ! gh auth status &>/dev/null; then
  print_error "GitHub CLI not authenticated"
  echo ""
  echo "Run: gh auth login"
  echo ""
  exit 1
fi

# Refuse ambiguous mixed tuple before any resolution side effects.
# --pr N plus positional issue numbers is structurally ambiguous: the caller
# cannot know which issue the workflow will act on.  Refuse loudly here and
# also in resolve_dispatch_key() so dry-run and real execution agree.
if [ -n "${PR_INPUT:-}" ] && [ ${#ARGS[@]} -gt 0 ]; then
  print_error "ambiguous invocation: --pr $PR_INPUT and positional issue(s) ${ARGS[*]} cannot be combined"
  echo "Use either --pr <number> or positional issue numbers, not both."
  exit 1
fi

# Resolve --pr to issue number
if [ -n "${PR_INPUT:-}" ]; then
  print_status "Resolving PR #$PR_INPUT..."
  PR_JSON=$(gh_safe pr view "$PR_INPUT" --json body,title,headRefName,state || true)
  PR_JSON="${PR_JSON:-}"
  if [ -z "$PR_JSON" ] || [ "$PR_JSON" = "null" ]; then
    print_error "Could not fetch PR #$PR_INPUT"
    exit 1
  fi
  PR_STATE=$(echo "$PR_JSON" | jq -r '.state // ""')
  if [ "$PR_STATE" != "OPEN" ]; then
    print_error "PR #$PR_INPUT is not open (state: $(echo "$PR_STATE" | tr '[:upper:]' '[:lower:]'))"
    exit 1
  fi
  PR_BODY=$(echo "$PR_JSON" | jq -r '.body // ""')
  LINKED_ISSUE=$(echo "$PR_BODY" | grep -oE '(Closes|closes|Fixes|fixes|Resolves|resolves) #[0-9]+' | head -1 | grep -oE '[0-9]+' || echo "")
  if [ -z "$LINKED_ISSUE" ]; then
    # Orphan PR — no linked issue. Handle based on staleness.
    PR_TITLE=$(echo "$PR_JSON" | jq -r '.title // ""')
    PR_BRANCH=$(echo "$PR_JSON" | jq -r '.headRefName // ""' || true)
    print_info "PR #$PR_INPUT has no linked issue"

    # Check staleness using remote branch (no local worktree needed)
    COMMITS_BEHIND=0
    if [ -n "$PR_BRANCH" ]; then
      git fetch origin main 2>/dev/null || true
      git fetch origin "$PR_BRANCH" 2>/dev/null || true
      MERGE_BASE=$(git merge-base "origin/$PR_BRANCH" "origin/main" 2>/dev/null || echo "")
      if [ -n "$MERGE_BASE" ]; then
        COMMITS_BEHIND=$(git rev-list --count "${MERGE_BASE}..origin/main" 2>/dev/null || echo "0")
      fi
    fi

    THRESHOLD="${RITE_STALE_BRANCH_THRESHOLD:-10}"

    # Shared cleanup: close PR and remove branch/worktree artifacts
    _close_orphan_pr() {
      local comment="$1"
      gh_safe pr comment "$PR_INPUT" --body "$comment" 2>/dev/null || true
      gh_safe pr close "$PR_INPUT" 2>/dev/null && print_info "Closed PR #$PR_INPUT" || print_warning "Failed to close PR #$PR_INPUT"
      if [ -n "$PR_BRANCH" ]; then
        LOCAL_WT=$(git worktree list 2>/dev/null | grep "\[$PR_BRANCH\]" | awk '{print $1}' || echo "")
        if [ -n "$LOCAL_WT" ] && [ -d "$LOCAL_WT" ]; then
          git worktree remove "$LOCAL_WT" --force 2>/dev/null && print_info "Removed worktree: $(basename "$LOCAL_WT")" || true
        fi
        git branch -D "$PR_BRANCH" 2>/dev/null && print_info "Deleted local branch: $PR_BRANCH" || true
        git push origin --delete "$PR_BRANCH" 2>/dev/null && print_info "Deleted remote branch: $PR_BRANCH" || true
      fi
    }

    if [ "$COMMITS_BEHIND" -ge "$THRESHOLD" ]; then
      print_warning "PR #$PR_INPUT is $COMMITS_BEHIND commits behind main (threshold: $THRESHOLD)"

      ORPHAN_RESTART=true
      if [ "${SUPERVISED:-false}" = true ]; then
        echo ""
        echo "Options:"
        echo "  1) Clean up only — close PR and delete branch/worktree, exit"
        echo "  2) Restart fresh — close PR, create issue, start new implementation"
        echo ""
        read -p "Choose [1/2]: " -n 1 -r
        echo
        [[ "$REPLY" != "2" ]] && ORPHAN_RESTART=false
      fi

      if [ "$ORPHAN_RESTART" = false ]; then
        _close_orphan_pr ":arrows_counterclockwise: Closing: Branch is ${COMMITS_BEHIND} commits behind main. No new issue created."
        print_success "Stale PR closed"
        exit 0
      fi

      # Create issue then close PR with reference to it
      if [ -n "$PR_BODY" ]; then
        ISSUE_BODY="$(printf 'Tracked from orphan PR #%s.\n\n---\n\n**Original PR description:**\n\n%s' "$PR_INPUT" "$PR_BODY")"
      else
        ISSUE_BODY="Tracked from orphan PR #${PR_INPUT}."
      fi
      ISSUE_URL=$(gh_safe issue create --title "$PR_TITLE" --body "$ISSUE_BODY" || true)
      ISSUE_URL="${ISSUE_URL:-}"
      LINKED_ISSUE=$(echo "$ISSUE_URL" | grep -oE '[0-9]+$' || echo "")
      if [ -z "$LINKED_ISSUE" ]; then
        print_error "Failed to create issue for PR #$PR_INPUT"
        exit 1
      fi
      print_success "Created issue #$LINKED_ISSUE"

      _close_orphan_pr ":arrows_counterclockwise: Closing: Branch is ${COMMITS_BEHIND} commits behind main.

Fresh implementation will be started on issue #${LINKED_ISSUE}."
      print_success "Stale PR closed — restarting fresh on issue #$LINKED_ISSUE"
    else
      # Not stale: create issue, link it in the PR body, continue normally
      if [ -n "$PR_BODY" ]; then
        ISSUE_BODY="$(printf 'Tracked from orphan PR #%s.\n\n---\n\n**Original PR description:**\n\n%s' "$PR_INPUT" "$PR_BODY")"
      else
        ISSUE_BODY="Tracked from orphan PR #${PR_INPUT}."
      fi
      ISSUE_URL=$(gh_safe issue create --title "$PR_TITLE" --body "$ISSUE_BODY" || true)
      ISSUE_URL="${ISSUE_URL:-}"
      LINKED_ISSUE=$(echo "$ISSUE_URL" | grep -oE '[0-9]+$' || echo "")
      if [ -z "$LINKED_ISSUE" ]; then
        print_error "Failed to create issue for PR #$PR_INPUT"
        exit 1
      fi
      print_success "Created issue #$LINKED_ISSUE"
      NEW_BODY="$(printf 'Closes #%s\n\n%s' "$LINKED_ISSUE" "$PR_BODY")"
      gh_safe pr edit "$PR_INPUT" --body "$NEW_BODY" 2>/dev/null \
        && print_success "Linked issue #$LINKED_ISSUE to PR #$PR_INPUT" \
        || print_warning "Could not update PR body (issue still created)"
    fi
  else
    print_success "PR #$PR_INPUT → issue #$LINKED_ISSUE"
  fi
  ARGS=("$LINKED_ISSUE")
  # Clear PR_INPUT after resolution so resolve_dispatch_key() sees only the
  # resolved issue in ARGS (prevents spurious mixed-pr-and-issues detection).
  PR_INPUT=""
fi

# Record a run to the persistent history file (independent of logs)
# Single file for all issues: .rite/run-history.log
# Format: "timestamp issue_number mode"
record_run() {
  local issue="$1" mode="$2"
  local history_file="$RITE_PROJECT_ROOT/$RITE_DATA_DIR/run-history.log"
  mkdir -p "$(dirname "$history_file")"
  echo "$(date -u +"%Y-%m-%dT%H:%M:%SZ") $issue $mode" >> "$history_file"
}

# Smart routing — all dispatch decisions derive from resolve_dispatch_key() so
# the routing logic has exactly one source of truth shared with the dry-run
# printer. No independent routing conditionals may appear in this section.
_DISPATCH_KEY=$(resolve_dispatch_key "$MODE" "${BATCH_FILTER_ARGS[*]:-}" "${PR_INPUT:-}" ${ARGS[@]+"${ARGS[@]}"})

# Target-branch preflight: verify (or auto-create) the target branch on origin.
# Scoped to workflow-running dispatch keys only — status/plan/undo paths stay
# network-free (doc §5.3). Gated on non-main so the default path pays zero
# network cost and no extra sourcing. Preflight failure exits before any LLM work.
case "$_DISPATCH_KEY" in
  single-issue|single-issue-text|batch-filter|batch-multi|dev-and-pr)
    if [ "${RITE_TARGET_BRANCH:-main}" != "main" ]; then
      source "$RITE_LIB_DIR/utils/stale-branch.sh"
      ensure_target_branch_exists "$RITE_TARGET_BRANCH" || exit 1
    fi
    ;;
esac

case "$_DISPATCH_KEY" in

  mixed-pr-and-issues)
    # Defense-in-depth: the early refusal block above (before --pr resolution)
    # handles this for the real path.  This branch catches any future code path
    # that could reach here with an uncleared PR_INPUT.
    print_error "ambiguous invocation: --pr ${PR_INPUT:-} and positional issue(s) ${ARGS[*]:-} cannot be combined"
    echo "Use either --pr <number> or positional issue numbers, not both."
    exit 1
    ;;

  status-repo-wide)
    source "$RITE_LIB_DIR/utils/repo-status.sh"
    repo_wide_status "${LABEL_FILTER:-}"
    exit 0
    ;;

  batch-filter)
    # Batch mode via filter (e.g., --label tech-debt)
    exec "$RITE_LIB_DIR/core/batch-process-issues.sh" "${BATCH_FILTER_ARGS[@]}" ${ARGS[@]+"${ARGS[@]}"} --auto
    ;;

  no-target)
    print_error "No issues specified"
    echo "Run 'rite --help' for usage"
    exit 1
    ;;

  single-issue|single-issue-text)
    normalize_and_resolve "${ARGS[0]}"
    record_run "$ISSUE_NUMBER" "full"
    # Full lifecycle: work -> PR -> review -> fixes -> merge
    # Default to unsupervised (--auto) unless --supervised was explicitly passed
    if [ "$SUPERVISED" = false ]; then
      exec "$RITE_LIB_DIR/core/workflow-runner.sh" "$ISSUE_NUMBER" --auto "${WORKFLOW_FLAGS[@]+"${WORKFLOW_FLAGS[@]}"}"
    else
      exec "$RITE_LIB_DIR/core/workflow-runner.sh" "$ISSUE_NUMBER" "${WORKFLOW_FLAGS[@]+"${WORKFLOW_FLAGS[@]}"}"
    fi
    ;;

  batch-multi)
    # Batch mode via multiple issue numbers
    print_info "Batch processing ${#ARGS[@]} issues"
    exec "$RITE_LIB_DIR/core/batch-process-issues.sh" "${ARGS[@]}" --auto
    ;;

  dev-and-pr)
    normalize_and_resolve "${ARGS[0]}"
    record_run "$ISSUE_NUMBER" "dev-and-pr"
    print_info "Dev + PR: issue #${ISSUE_NUMBER} (work + PR, skip review/merge)"
    "$RITE_LIB_DIR/core/claude-workflow.sh" "$ISSUE_NUMBER" --auto
    # Pass $ISSUE_NUMBER so create-pr.sh's resolver can use the state-file tier
    # on resume without requiring the --branch/--base flag to be re-supplied.
    "$RITE_LIB_DIR/core/create-pr.sh" --auto "$ISSUE_NUMBER"
    print_success "Dev + PR complete — PR created, skipping review/merge"
    exit 0
    ;;

  status-per-issue)
  # Status mode: read-only overview of issue workflow state
  # Skips normalize_and_resolve (no Claude call needed for status)
  STATUS_ISSUE="${ARGS[0]}"
  if [[ ! "$STATUS_ISSUE" =~ ^[0-9]+$ ]]; then
    print_error "--status requires an issue number"
    exit 1
  fi

  # Reject bare PR numbers before doing any work.
  # run_workflow()'s /pull/ guard does not cover --status (it routes through
  # pr-detection.sh directly). Mirror the same guard here.
  # See: _reject_if_pr_number() above and exit code 15 in exit-codes.md.
  _reject_if_pr_number "$STATUS_ISSUE"

  source "$RITE_LIB_DIR/utils/pr-detection.sh"

  # ── Issue info ──
  ISSUE_JSON=$(gh_safe issue view "$STATUS_ISSUE" --json title,state,createdAt,closedAt,labels,url || true)
  ISSUE_JSON="${ISSUE_JSON:-}"
  if [ -z "$ISSUE_JSON" ] || [ "$ISSUE_JSON" = "null" ]; then
    print_error "Issue #$STATUS_ISSUE not found"
    exit 1
  fi

  ISSUE_TITLE=$(echo "$ISSUE_JSON" | jq -r '.title')
  ISSUE_STATE=$(echo "$ISSUE_JSON" | jq -r '.state')
  ISSUE_CREATED=$(echo "$ISSUE_JSON" | jq -r '.createdAt // ""' | cut -dT -f1)
  ISSUE_LABELS=$(echo "$ISSUE_JSON" | jq -r '[.labels[].name] | join(", ")' 2>/dev/null || echo "")

  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo " Issue #$STATUS_ISSUE: $ISSUE_TITLE"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""

  # State indicator
  if [ "$ISSUE_STATE" = "CLOSED" ]; then
    echo "  State:      CLOSED (since $(echo "$ISSUE_JSON" | jq -r '.closedAt // ""' | cut -dT -f1))"
  else
    echo "  State:      OPEN (created $ISSUE_CREATED)"
  fi
  [ -n "$ISSUE_LABELS" ] && echo "  Labels:     $ISSUE_LABELS"
  ISSUE_URL=$(echo "$ISSUE_JSON" | jq -r '.url // ""')
  [ -n "$ISSUE_URL" ] && echo "  URL:        $ISSUE_URL"

  # ── PR info ──
  # detect_pr_for_issue searches open PRs only. For closed/merged issues,
  # fall back to searching merged then closed PRs.
  if ! detect_pr_for_issue "$STATUS_ISSUE"; then
    PR_NUMBER=$(gh_safe pr list --state merged --json number,body --limit 100 | \
      jq --arg issue "$STATUS_ISSUE" -r \
      '.[] | select(.body | test("(Closes|closes|Fixes|fixes|Resolves|resolves) #" + $issue + "\\b")) | .number' | \
      head -1 || true)
    PR_NUMBER="${PR_NUMBER:-}"
    if [ -z "$PR_NUMBER" ] || [ "$PR_NUMBER" = "null" ]; then
      PR_NUMBER=$(gh_safe pr list --state closed --json number,body --limit 100 | \
        jq --arg issue "$STATUS_ISSUE" -r \
        '.[] | select(.body | test("(Closes|closes|Fixes|fixes|Resolves|resolves) #" + $issue + "\\b")) | .number' | \
        head -1 || true)
      PR_NUMBER="${PR_NUMBER:-}"
    fi
    [ -z "$PR_NUMBER" ] || [ "$PR_NUMBER" = "null" ] && PR_NUMBER=""
  fi
  if [ -n "$PR_NUMBER" ]; then
    PR_JSON=$(gh_safe pr view "$PR_NUMBER" --json state,title,headRefName,additions,deletions,changedFiles,commits,createdAt,mergedAt || true)
    PR_JSON="${PR_JSON:-"{}"}"
    PR_STATE=$(echo "$PR_JSON" | jq -r '.state // "UNKNOWN"')
    PR_BRANCH_NAME=$(echo "$PR_JSON" | jq -r '.headRefName // ""' || true)
    PR_ADDITIONS=$(echo "$PR_JSON" | jq -r '.additions // 0')
    PR_DELETIONS=$(echo "$PR_JSON" | jq -r '.deletions // 0')
    PR_FILES=$(echo "$PR_JSON" | jq -r '.changedFiles // 0')
    PR_COMMITS=$(echo "$PR_JSON" | jq -r '.commits | length // 0')
    PR_CREATED=$(echo "$PR_JSON" | jq -r '.createdAt // ""' | cut -dT -f1)

    echo ""
    echo "  PR:         #$PR_NUMBER ($PR_STATE)"
    echo "  Branch:     $PR_BRANCH_NAME"
    echo "  Changes:    $PR_FILES file(s), +$PR_ADDITIONS -$PR_DELETIONS"
    echo "  Commits:    $PR_COMMITS (since $PR_CREATED)"

    if [ "$PR_STATE" = "MERGED" ]; then
      PR_MERGED=$(echo "$PR_JSON" | jq -r '.mergedAt // ""' | cut -dT -f1)
      echo "  Merged:     $PR_MERGED"
    fi

    # ── Worktree ──
    if detect_worktree_for_pr "$PR_NUMBER"; then
      echo "  Worktree:   $WORKTREE_PATH"

      # Check for uncommitted changes
      UNCOMMITTED=$(git -C "$WORKTREE_PATH" status --porcelain 2>/dev/null | grep -cvE "^\?\?" || true)
      if [ "$UNCOMMITTED" -gt 0 ]; then
        echo "  Uncommitted: $UNCOMMITTED file(s)"
      fi

      # Check for unpushed commits
      _WT_BRANCH=$(git -C "$WORKTREE_PATH" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
      _WT_LOCAL=$(git -C "$WORKTREE_PATH" rev-parse HEAD 2>/dev/null || echo "")
      _WT_REMOTE=$(git -C "$WORKTREE_PATH" rev-parse "origin/$_WT_BRANCH" 2>/dev/null || echo "")
      if [ "$_WT_LOCAL" != "$_WT_REMOTE" ] && [ -n "$_WT_LOCAL" ] && [ -n "$_WT_REMOTE" ]; then
        _UNPUSHED=$(git -C "$WORKTREE_PATH" log --oneline "origin/$_WT_BRANCH..HEAD" 2>/dev/null | wc -l | tr -d ' ')
        echo "  Unpushed:   $_UNPUSHED commit(s)"
      fi

      # Check how far behind main
      _MB=$(git -C "$WORKTREE_PATH" merge-base HEAD origin/main 2>/dev/null || echo "")
      if [ -n "$_MB" ]; then
        _BEHIND=$(git -C "$WORKTREE_PATH" rev-list --count "${_MB}..origin/main" 2>/dev/null || echo "0")
        if [ "$_BEHIND" -gt 0 ]; then
          if [ "$_BEHIND" -ge "${RITE_STALE_BRANCH_THRESHOLD:-10}" ]; then
            echo -e "  Behind main: ${RED}$_BEHIND commits (will restart fresh)${NC}"
          else
            echo "  Behind main: $_BEHIND commits (will auto-merge main)"
          fi
        else
          echo "  Behind main: up to date"
        fi
      fi
    else
      echo "  Worktree:   none"
    fi

    # ── Review state ──
    detect_review_state "$PR_NUMBER" "${WORKTREE_PATH:-}"

    echo ""
    if [ "$HAS_REVIEW" = "true" ]; then
      # Extract model and timestamp from review marker
      REVIEW_MODEL=$(echo "$REVIEW_BODY" | grep -oE 'model:[a-z0-9-]+' | head -1 | sed 's/model://' || echo "unknown")
      REVIEW_DATE=$(echo "$REVIEW_TIME" | cut -dT -f1)
      if [ "$REVIEW_IS_CURRENT" = "true" ]; then
        echo "  Review:     Current ($REVIEW_MODEL, $REVIEW_DATE)"
      else
        echo "  Review:     Stale ($REVIEW_MODEL, $REVIEW_DATE) — code pushed since"
      fi

      # Extract findings summary from review body
      FINDINGS_LINE=$(echo "$REVIEW_BODY" | grep -oE "CRITICAL: [0-9]+ \| HIGH: [0-9]+ \| MEDIUM: [0-9]+ \| LOW: [0-9]+" | head -1 || echo "")
      [ -n "$FINDINGS_LINE" ] && echo "  Findings:   $FINDINGS_LINE"
    else
      echo "  Review:     None"
    fi

    # ── Assessment state ──
    _jq_assess_body="[.comments[] | select(.body | contains(\"<!-- ${RITE_MARKER_ASSESSMENT}\"))] | sort_by(.createdAt) | reverse | .[0].body // \"\""
    ASSESS_BODY=$(gh_safe pr view "$PR_NUMBER" --json comments --jq "$_jq_assess_body" || true)
    ASSESS_BODY="${ASSESS_BODY:-}"

    if [ -n "$ASSESS_BODY" ] && [ "$ASSESS_BODY" != "" ]; then
      NOW_CT=$(echo "$ASSESS_BODY" | grep -c "^### .* - ACTIONABLE_NOW" || true)
      LATER_CT=$(echo "$ASSESS_BODY" | grep -c "^### .* - ACTIONABLE_LATER" || true)
      DISMISSED_CT=$(echo "$ASSESS_BODY" | grep -c "^### .* - DISMISSED" || true)
      echo "  Assessment: NOW=$NOW_CT  LATER=$LATER_CT  DISMISSED=$DISMISSED_CT"
    else
      echo "  Assessment: None"
    fi

    # ── Follow-up issues ──
    _jq_followup_nums="[.comments[].body | capture(\"${RITE_MARKER_FOLLOWUP}:(?<num>[0-9]+)\") | .num] | join(\", \")"
    FOLLOWUP_MARKERS=$(gh_safe pr view "$PR_NUMBER" --json comments --jq "$_jq_followup_nums" || true)
    FOLLOWUP_MARKERS="${FOLLOWUP_MARKERS:-}"

    if [ -n "$FOLLOWUP_MARKERS" ]; then
      echo "  Follow-ups: #$FOLLOWUP_MARKERS"
    fi
  else
    echo ""
    echo "  PR:         None"
  fi

  # ── Session state ──
  STATE_FILE="${RITE_PROJECT_ROOT}/${RITE_DATA_DIR}/session-state-${STATUS_ISSUE}.json"
  if [ -f "$STATE_FILE" ]; then
    SAVED_PHASE=$(jq -r '.phase // "unknown"' "$STATE_FILE" 2>/dev/null)
    SAVED_REASON=$(jq -r '.reason // "unknown"' "$STATE_FILE" 2>/dev/null)
    SAVED_RETRY=$(jq -r '.retry_count // 0' "$STATE_FILE" 2>/dev/null)
    SAVED_AT=$(jq -r '.saved_at_human // ""' "$STATE_FILE" 2>/dev/null)
    echo ""
    echo "  Session:    Saved at phase '$SAVED_PHASE' ($SAVED_REASON)"
    [ "$SAVED_RETRY" -gt 0 ] 2>/dev/null && echo "  Retries:    $SAVED_RETRY/3"
    [ -n "$SAVED_AT" ] && echo "  Saved at:   $SAVED_AT"
  fi

  # ── Runs ──
  HISTORY_FILE="$RITE_PROJECT_ROOT/$RITE_DATA_DIR/run-history.log"
  RUN_COUNT=0
  LAST_RUN=""
  if [ -f "$HISTORY_FILE" ]; then
    RUN_COUNT=$(grep -c " ${STATUS_ISSUE} " "$HISTORY_FILE" || true)
    LAST_RUN=$(grep " ${STATUS_ISSUE} " "$HISTORY_FILE" | tail -1 || echo "")
  fi
  LOG_DIR="$RITE_PROJECT_ROOT/$RITE_DATA_DIR/logs"
  LATEST_LOG=""
  if [ -d "$LOG_DIR" ]; then
    LATEST_LOG=$(ls -1t "$LOG_DIR"/rite-${STATUS_ISSUE}-*.log 2>/dev/null | head -1 || true)
  fi
  if [ "$RUN_COUNT" -gt 0 ]; then
    echo ""
    LAST_TIME=$(echo "$LAST_RUN" | cut -d' ' -f1 | cut -dT -f1)
    LAST_MODE=$(echo "$LAST_RUN" | cut -d' ' -f3-)
    echo "  Runs:       $RUN_COUNT total (last: $LAST_MODE on $LAST_TIME)"
    [ -n "$LATEST_LOG" ] && echo "  Latest log: $(basename "$LATEST_LOG")"
  fi

  # ── Phase indicator ──
  echo ""
  if [ "$ISSUE_STATE" = "CLOSED" ]; then
    echo "  Phase:      Complete"
  elif [ -z "${PR_NUMBER:-}" ]; then
    echo "  Phase:      Not started — run 'rite $STATUS_ISSUE --dev-and-pr'"
  elif [ "$HAS_REVIEW" != "true" ]; then
    echo "  Phase:      Needs review — run 'rite $STATUS_ISSUE --review-latest'"
  elif [ "$REVIEW_IS_CURRENT" != "true" ]; then
    echo "  Phase:      Review stale — run 'rite $STATUS_ISSUE --review-latest'"
  elif [ -n "$ASSESS_BODY" ] && [ "${NOW_CT:-0}" -gt 0 ]; then
    echo "  Phase:      Needs fixes ($NOW_CT items) — run 'rite $STATUS_ISSUE --assess-and-fix'"
  elif [ -z "$ASSESS_BODY" ] || [ "$ASSESS_BODY" = "" ]; then
    echo "  Phase:      Needs assessment — run 'rite $STATUS_ISSUE --assess-and-fix'"
  else
    echo "  Phase:      Ready to merge — run 'rite $STATUS_ISSUE'"
  fi

  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  exit 0
    ;;

  review-latest)
    # Reject bare PR numbers before normalize_and_resolve (which would succeed
    # for PR numbers via `gh issue view`, silently operating on a PR).
    # See: _reject_if_pr_number() and exit code 15 in exit-codes.md.
    if [[ "${ARGS[0]:-}" =~ ^[0-9]+$ ]]; then
      _reject_if_pr_number "${ARGS[0]}"
    fi
    normalize_and_resolve "${ARGS[0]}"
    record_run "$ISSUE_NUMBER" "review-latest"
    source "$RITE_LIB_DIR/utils/pr-detection.sh"

  # Find PR for this issue
  if ! detect_pr_for_issue "$ISSUE_NUMBER"; then
    print_error "No open PR found for issue #$ISSUE_NUMBER"
    print_info "Run 'rite $ISSUE_NUMBER --dev-and-pr' first to create a PR"
    exit 1
  fi
  print_info "Found PR #$PR_NUMBER for issue #$ISSUE_NUMBER"

  # Check if PR has any code changes.
  # wc -c (byte count) instead of wc -l avoids a false-zero when the diff output
  # contains exactly one line with no trailing newline — wc -l would return 0 in
  # that case even though real content exists (wc -l counts newline characters).
  DIFF_BYTES=$(gh_safe pr diff "$PR_NUMBER" | wc -c | tr -d ' ' || true)
  DIFF_BYTES="${DIFF_BYTES:-0}"
  if [ "${DIFF_BYTES:-0}" -eq 0 ]; then
    print_error "No code to review — issue #$ISSUE_NUMBER has no diff from main"
    exit 1
  fi

  # Detect worktree for more accurate timestamp comparison
  detect_worktree_for_pr "$PR_NUMBER" 2>/dev/null || true
  detect_review_state "$PR_NUMBER" "${WORKTREE_PATH:-}"

  if [ "$HAS_REVIEW" = "true" ] && [ "$REVIEW_IS_CURRENT" = "true" ]; then
    # Review exists and is current — show it, prompt if supervised
    echo ""
    print_info "Current review exists for issue #$ISSUE_NUMBER:"
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    # Strip HTML comment markers for display
    echo "$REVIEW_BODY" | sed '/^<!-- sharkrite-/d; /^-->$/d'
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    if [ "$SUPERVISED" = true ]; then
      read -p "Review is still current. Re-review anyway? (y/n) " -n 1 -r
      echo
      if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        print_info "Review is current — no action taken"
        exit 0
      fi
    else
      print_info "Review is current — no action needed"
      exit 0
    fi
  elif [ "$HAS_REVIEW" = "true" ]; then
    print_info "Review exists but is stale (code pushed since) — generating fresh review"
  else
    print_info "No existing review — generating review"
  fi

  # Generate and post review
  if [ "$SUPERVISED" = true ]; then
    "$RITE_LIB_DIR/core/local-review.sh" "$PR_NUMBER" --post
  else
    "$RITE_LIB_DIR/core/local-review.sh" "$PR_NUMBER" --post --auto
  fi
  print_success "Review posted for issue #$ISSUE_NUMBER"
  exit 0
    ;;

  assess-and-fix)
    # Reject bare PR numbers before normalize_and_resolve (which would succeed
    # for PR numbers via `gh issue view`, silently operating on a PR).
    # See: _reject_if_pr_number() and exit code 15 in exit-codes.md.
    if [[ "${ARGS[0]:-}" =~ ^[0-9]+$ ]]; then
      _reject_if_pr_number "${ARGS[0]}"
    fi
    normalize_and_resolve "${ARGS[0]}"
    record_run "$ISSUE_NUMBER" "assess-and-fix"
    source "$RITE_LIB_DIR/utils/pr-detection.sh"

  # Find PR for this issue
  if ! detect_pr_for_issue "$ISSUE_NUMBER"; then
    print_error "No open PR found for issue #$ISSUE_NUMBER"
    print_info "Run 'rite $ISSUE_NUMBER --dev-and-pr' first"
    exit 1
  fi
  print_info "Found PR #$PR_NUMBER for issue #$ISSUE_NUMBER"

  # Find worktree
  if ! detect_worktree_for_pr "$PR_NUMBER"; then
    print_error "No worktree found for issue #$ISSUE_NUMBER"
    print_info "Run 'rite $ISSUE_NUMBER --dev-and-pr' first to create a worktree"
    exit 1
  fi
  print_info "Using worktree: $WORKTREE_PATH"

  # Check for current review
  detect_review_state "$PR_NUMBER" "$WORKTREE_PATH"
  if [ "$HAS_REVIEW" != "true" ] || [ "$REVIEW_IS_CURRENT" != "true" ]; then
    print_error "No current review found for issue #$ISSUE_NUMBER"
    if [ "$HAS_REVIEW" = "true" ]; then
      print_info "Review exists but is stale (code pushed since last review)"
    fi
    print_info "Run 'rite $ISSUE_NUMBER --review-latest' first"
    exit 1
  fi

  # Assess and fix loop
  CLAUDE_WORKFLOW="$RITE_LIB_DIR/core/claude-workflow.sh"
  CREATE_PR="$RITE_LIB_DIR/core/create-pr.sh"
  ASSESS_RESOLVE="$RITE_LIB_DIR/core/assess-and-resolve.sh"

  cd "$WORKTREE_PATH"

  RETRY=0
  MAX_RETRIES=3
  FINAL_EXIT=0

  while true; do
    print_info "Assessment round $((RETRY + 1)) of $((MAX_RETRIES + 1))"

    # Run assessment. assess-and-resolve.sh routes display output to stderr
    # and pipes filtered assessment content to stdout on exit 2.
    # We capture stdout (assessment data) and let stderr stream to terminal.
    ASSESS_STDOUT=$(mktemp)
    set +e
    "$ASSESS_RESOLVE" "$PR_NUMBER" "$ISSUE_NUMBER" "$RETRY" --auto > "$ASSESS_STDOUT"
    ASSESS_EXIT=$?
    set -e

    ASSESS_CONTENT=$(cat "$ASSESS_STDOUT")
    rm -f "$ASSESS_STDOUT"

    if [ $ASSESS_EXIT -eq 0 ]; then
      # Done — assessment passes (may have created follow-up issues)
      print_success "Assessment complete — issue #$ISSUE_NUMBER is ready to merge"
      FINAL_EXIT=0
      break

    elif [ $ASSESS_EXIT -eq 2 ]; then
      # ACTIONABLE_NOW items found — fix and loop
      if [ $RETRY -ge $MAX_RETRIES ]; then
        print_error "Maximum retries ($MAX_RETRIES) reached"
        FINAL_EXIT=1
        break
      fi

      print_info "ACTIONABLE_NOW items found — running fix cycle (retry $((RETRY + 1))/$MAX_RETRIES)"

      # Run Claude in fix mode
      cd "$WORKTREE_PATH"
      set +e
      RITE_ORCHESTRATED=true "$CLAUDE_WORKFLOW" "$ISSUE_NUMBER" --fix-review --pr-number "$PR_NUMBER" --auto
      FIX_EXIT=$?
      set -e

      if [ $FIX_EXIT -ne 0 ]; then
        print_error "Fix cycle failed (exit code: $FIX_EXIT)"
        FINAL_EXIT=1
        break
      fi

      # Push fixes and trigger fresh review
      # Pass $ISSUE_NUMBER so create-pr.sh's resolver can use the state-file tier
      # on resume without requiring the --branch/--base flag to be re-supplied.
      cd "$WORKTREE_PATH"
      set +e
      "$CREATE_PR" --auto "$ISSUE_NUMBER"
      PUSH_EXIT=$?
      set -e

      if [ $PUSH_EXIT -ne 0 ] && [ $PUSH_EXIT -ne 2 ]; then
        print_error "Push/review failed (exit code: $PUSH_EXIT)"
        FINAL_EXIT=1
        break
      fi

      RETRY=$((RETRY + 1))

    elif [ $ASSESS_EXIT -eq 3 ]; then
      # Stale review — push + fresh review, don't increment retry
      print_info "Review is stale — triggering fresh review"
      # Pass $ISSUE_NUMBER so create-pr.sh's resolver can use the state-file tier
      # on resume without requiring the --branch/--base flag to be re-supplied.
      cd "$WORKTREE_PATH"
      set +e
      "$CREATE_PR" --auto "$ISSUE_NUMBER"
      set -e

    else
      # Exit 1 or other — manual intervention needed
      print_error "Assessment requires manual intervention (exit code: $ASSESS_EXIT)"
      FINAL_EXIT=1
      break
    fi
  done

  exit $FINAL_EXIT
    ;;

  undo)
    # Undo mode: no normalization needed, just validate and pass through
    if [[ ! "${ARGS[0]}" =~ ^[0-9]+$ ]]; then
      print_error "--undo requires an issue number, not a description"
      exit 1
    fi
    exec "$RITE_LIB_DIR/core/undo-workflow.sh" "${ARGS[0]}"
    ;;

  undo-bad-args)
    # undo requires exactly one issue number.
    print_error "--undo requires exactly one issue number"
    echo "Usage: rite <issue-number> --undo"
    exit 1
    ;;

  ""|*)
    # Empty key = unrecognized tuple.
    print_error "unsupported invocation (mode=$MODE args=[${ARGS[*]:-}] filter=[${BATCH_FILTER_ARGS[*]:-}] pr=[${PR_INPUT:-}])"
    echo "Run 'rite --help' for usage"
    exit 1
    ;;

esac
