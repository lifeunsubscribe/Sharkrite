# Sharkrite shellcheck configuration.
#
# Declares the project's shell style and excludes shellcheck rules that
# conflict with it. The goal is a green CI gate that flags real bug risk
# (warnings/errors) while ignoring style preferences the project has
# deliberately chosen against. See CLAUDE.md → "Shell style" for the
# canonical policy and the reasons behind each disable.

# Shell dialect
shell=bash

# NOTE: Minimum severity is set in the Makefile via --severity=warning, not
# here. As of shellcheck 0.11.0 the `severity=` rcfile directive is ignored
# (info-level rules still fire even with `severity=warning`). The CLI flag
# works correctly. Track shellcheck issue if-and-when an upstream fix lands.

# Source handling — sharkrite sources files via $RITE_LIB_DIR at runtime;
# shellcheck cannot follow these statically.
disable=SC1090   # Can't follow non-constant source
disable=SC1091   # Not following sourced files (sourced via config.sh)

# Pure-style rules disabled (no correctness impact).
# Codebase de facto convention is bare $VAR (2514 vs 397 braced) and
# POSIX [ ] (1391 vs 100 [[ ]]) — both work fine when properly quoted.
disable=SC2250   # Prefer ${VAR} braces — project uses bare $VAR
disable=SC2292   # Prefer [[ ]] over [ ] — project uses POSIX [ ]
disable=SC2248   # Quote to prevent X — over-broad for our patterns
disable=SC2236   # Prefer -n over ! -z — readability preference
disable=SC2126   # Prefer grep -c over grep | wc -l — readability preference
disable=SC2001   # Prefer parameter expansion over sed — sed is fine here
disable=SC2129   # Consider grouped { cmd; cmd; } >> file — minor preference

# Info-level rules disabled (advisory, high false-positive rate in our code).
disable=SC2312   # Consider invoking command separately — overlaps with SC2155
disable=SC2310   # function in set -e context — advisory, no clear action
disable=SC2317   # Command appears unreachable — false positives in trap handlers
disable=SC2249   # Consider adding default *) case — defensive but noisy
disable=SC2016   # Expressions don't expand in single quotes — usually intentional
disable=SC2086   # Quote to prevent splitting — covered by our own SC equivalents

# Known technical debt parked for follow-up issues — DO NOT add new
# violations of these rules. The current count is locked in so that any
# new occurrence shows up in lint output below the disable threshold.
# When the count reaches zero, drop the disable lines.
disable=SC2155   # Declare and assign separately (125 occurrences as of 2026-06-04)
                 #   Real risk: `local foo=$(cmd)` masks cmd's exit code under set -e.
                 #   Covered partially by CLAUDE.md "Silent death" guidance.
                 #   Follow-up: clean up incrementally; new code must avoid this pattern.
disable=SC2034   # Unused variables (49 occurrences as of 2026-06-04)
                 #   Some are intentional (exported config), some are dead code.
                 #   Follow-up: audit and either annotate (# shellcheck disable inline)
                 #   or remove. New unused vars must be addressed at PR time.
