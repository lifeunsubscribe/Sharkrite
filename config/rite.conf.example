#!/bin/bash
# ~/.config/rite/config - Global Sharkrite configuration
# These settings apply across all projects unless overridden by project config.
# Copy to: ~/.config/rite/config

# =============================================================================
# Worktree Management
# =============================================================================

# Base directory for all project worktrees
# Each project gets a subdirectory: $RITE_WORKTREE_BASE/<project>-worktrees/
# RITE_WORKTREE_BASE="$HOME/Dev/rite-worktrees"

# =============================================================================
# Session Limits
# =============================================================================

# Maximum issues to process before requiring fresh session
# RITE_MAX_ISSUES_PER_SESSION=8

# Maximum hours before session timeout
# RITE_MAX_SESSION_HOURS=4

# Maximum auto-fix retries before creating follow-up issue
# RITE_MAX_RETRIES=3

# Claude CLI timeout for assessment (seconds)
# Default is 300s. Raise to 600 if assessments time out during heavy provider load.
# RITE_ASSESSMENT_TIMEOUT=300

# =============================================================================
# Notifications (optional)
# =============================================================================

# Enable notifications for this config scope (default: false)
# Notifications are opt-in — even if SLACK_WEBHOOK is set in your environment,
# notifications won't fire unless this is explicitly set to "true".
# RITE_NOTIFICATIONS="true"

# Slack webhook URL for workflow notifications
# SLACK_WEBHOOK="https://hooks.slack.com/services/..."

# Email for notifications (requires AWS SES)
# EMAIL_NOTIFICATION_ADDRESS="you@example.com"

# AWS profile for SES/SNS notifications
# RITE_AWS_PROFILE="default"

# SNS topic ARN for SMS notifications (urgent blockers only)
# RITE_SNS_TOPIC_ARN=""

# Email sender address (requires SES verified identity)
# RITE_EMAIL_FROM=""

# =============================================================================
# AWS Integration (optional)
# =============================================================================

# AWS credential checks are auto-detected from repo dependencies and IaC markers.

# =============================================================================
# Provider Selection (per-phase)
# =============================================================================

# claude is the only shipped provider; all default to "claude". The per-phase
# vars remain so the codebase stays provider-neutral.

# Provider for development + fix sessions (agentic with tool restrictions)
# RITE_DEV_PROVIDER="claude"

# Provider for reviews, assessments, and planning (text-in/text-out)
# RITE_REVIEW_PROVIDER="claude"

# Provider for utility calls (classification, normalization, health reports)
# RITE_UTILITY_PROVIDER="claude"

# Claude models
# RITE_CLAUDE_MODEL="claude-sonnet-4-5"
# RITE_REVIEW_MODEL="claude-opus-4-5"

# =============================================================================
# Test Gate
# =============================================================================

# Override the test runner for non-Sharkrite repos.
# When set, this command is run verbatim instead of the auto-detected runner
# (Makefile test:, npm test, pytest, cargo test, go test ./...).
# Sharkrite repos (detected by shellcheck: + lint: Makefile targets) always
# use make shellcheck + make lint + bats; this override is ignored for them.
#
# Use this for repos whose test runner is not in the auto-detection table:
#   RITE_TEST_COMMAND="./run-tests.sh"
#   RITE_TEST_COMMAND="cargo test --features integration"
#   RITE_TEST_COMMAND="pio test"                   # PlatformIO (Arduino)
#   RITE_TEST_COMMAND="arduino-cli compile --fqbn arduino:avr:uno ."
#   RITE_TEST_COMMAND="bundle exec rspec"          # Ruby
#   RITE_TEST_COMMAND="mvn test -q"                # Maven
#
# Shell flavor: the command runs under `sh -c`, not bash. Avoid bashisms
# (arrays, [[ ]], bash-specific builtins). If your runner script uses bash
# features, invoke bash explicitly:
#   RITE_TEST_COMMAND="bash ./run-tests.sh"
#
# Without this set, the gate skips (and warns if the PR touched source files).
# RITE_TEST_COMMAND=""

# Override the git diff base used by the test gate for targeted test selection.
# Default is origin/main. Override for non-standard branch setups or CI.
# RITE_TEST_GATE_DIFF_BASE="origin/main"
