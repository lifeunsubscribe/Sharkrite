#!/bin/bash
# .rite/config - Project-specific Sharkrite configuration
# Place this file at $REPO_ROOT/.rite/config
# These settings override global config for this project only.

# =============================================================================
# Project Identity
# =============================================================================

# Override auto-detected project name (defaults to repo directory name)
# RITE_PROJECT_NAME="my-project"

# =============================================================================
# Worktree Location
# =============================================================================

# Override worktree directory for this project
# RITE_WORKTREE_DIR="$HOME/Dev/my-project-worktrees"

# =============================================================================
# Scratchpad Location
# =============================================================================

# Override scratchpad file path (defaults to .rite/scratch.md)
# SCRATCHPAD_FILE="$RITE_PROJECT_ROOT/.rite/scratch.md"

# =============================================================================
# AWS Integration
# =============================================================================

# AWS credential checks are auto-detected from repo dependencies and IaC markers.
# Override the detected profile if needed:
# AWS profile override for this project
# RITE_AWS_PROFILE="my-aws-profile"

# =============================================================================
# Notifications (opt-in)
# =============================================================================

# Enable notifications for this project (default: false)
# RITE_NOTIFICATIONS="true"

# Slack webhook URL (or set globally in ~/.config/rite/config)
# SLACK_WEBHOOK="https://hooks.slack.com/services/..."

# =============================================================================
# Provider Selection (per-phase, overrides global config)
# =============================================================================

# claude is the only shipped provider; these default to "claude". The per-phase
# vars exist so the codebase stays provider-neutral.
# RITE_DEV_PROVIDER="claude"
# RITE_REVIEW_PROVIDER="claude"
# RITE_UTILITY_PROVIDER="claude"

# =============================================================================
# Workflow Defaults
# =============================================================================

# Default workflow mode: supervised or unsupervised
# WORKFLOW_MODE="supervised"

# Assessment timeout for this project (complex projects may need longer)
# Default is 300s. Raise to 600 if assessments time out during heavy provider load.
# RITE_ASSESSMENT_TIMEOUT=300

# Follow-up issue dedup backoff (seconds between retry iterations; default: 5s)
# Under slow-GitHub conditions the lock holder can spend up to
# (RITE_GH_MAX_RETRIES * gh backoff) + (_dedup_max_retries * RITE_DEDUP_BACKOFF)
# seconds inside the lock.  The waiter times out after 60s.  Lowering this value
# reduces worst-case holder time.  See timing budget in lib/utils/issue-lock.sh.
# RITE_DEDUP_BACKOFF=5

# Per-finding follow-up issue cap (default: 20).
# Limits the number of GitHub issues created per assess run to prevent unbounded
# API usage on reviews with many findings.  Each finding triggers full dedup
# machinery (issue list + issue view + pr view + backoff sleeps), scaling N×.
# When the cap is reached, a [diag] FOLLOWUP_CAP_HIT line is emitted and a
# warning is printed with the count of skipped findings.
# Set to 0 to disable the cap entirely (unbounded — original behavior).
# RITE_MAX_FINDINGS_PER_RUN=20

# =============================================================================
# Plan Command (rite plan)
# =============================================================================

# Default architectural doc(s) for `rite plan` when no doc path is specified.
# Space-separated, relative to project root.
# RITE_PLAN_DOCS="docs/architecture/implementation-phases.md docs/roadmap.md"

# Maximum time estimate per issue before requiring decomposition (default: 2hr)
# RITE_PLAN_MAX_ESTIMATE="2hr"

# Auto-discovery byte cap for grounding docs injected into the plan prompt.
#
# `rite plan` automatically discovers and injects ADRs, README.md, and other
# docs/**/*.md files as authoritative grounding context. This prevents the
# planner from generating issues that conflict with documented constraints.
#
# Priority order within the cap:
#   1. ADRs (docs/**/*adr*.md, docs/ADR-*.md) — loaded in full, highest priority
#   2. README.md — loaded in full
#   3. Other docs/**/*.md — loaded alphabetically until cap is reached
#
# ADRs and README always load in full even if the cap is already exceeded.
# Other docs are skipped (with a logged warning) when the budget runs out.
#
# Default: 50000 (50KB). Raise for doc-heavy projects; lower for fast iteration.
# Set to 0 to disable auto-discovery entirely (explicit doc_paths still work).
# RITE_PLAN_DOC_BYTE_CAP=50000

# Whether to auto-inject the root README.md when running `rite plan`.
# Default: true (README is included as high-priority grounding context).
# Set to false or 0 to skip README injection — useful when the README is very
# large (e.g. a monorepo megadoc) or is not relevant to the planning session.
# ADRs and docs/**/*.md auto-discovery are unaffected by this toggle.
# RITE_PLAN_INCLUDE_README=true

# =============================================================================
# Unverified External Integration Detection (rite plan post-generation pass)
# =============================================================================

# Path to a custom additional fixture directory for grounding detection.
# Any hostname or package name that appears as a subdirectory under this path
# (or under the always-scanned "fixtures/" and "tests/fixtures/") is considered
# "grounded" and will not trigger a spike-issue prerequisite.
# Supply a single directory path; trailing /** or /* are stripped automatically.
# The walk is recursive (all subdirectory depths), so nested fixture layouts
# such as test/vcr_cassettes/prod/api.example.com/ are fully covered.
# Brace expansion is NOT supported.  Leave unset to use only the two default
# directories (fixtures/ and tests/fixtures/).
# Example: RITE_PLAN_FIXTURE_GLOB="test/vcr_cassettes/**"
# RITE_PLAN_FIXTURE_GLOB=""

# Set to "1" to skip the _detect_unverified_integrations pass entirely.
# Useful when the project has intentionally ungrounded integrations or the
# check is producing false positives for a specific planning run.
# Default: "0" (pass is active)
# RITE_PLAN_SKIP_INTEGRATION_CHECK=0

# =============================================================================
# Documentation
# =============================================================================

# Sharkrite maintains internal docs at .rite/docs/ automatically.
# No configuration needed for internal docs.

# To enable project doc sync, create .rite/doc-sync.md with instructions
# for which project docs to update and how. See templates/doc-sync.md
# for the format. If .rite/doc-sync.md does not exist, only internal
# docs are maintained.
